{
  "name": "butemine-school-website",
  "version": "1.0.0",
  "description": "Official website for Butemine English Medium Pre & Primary School, Tanzania",
  "main": "server.js",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./public/css/style.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./public/css/style.css --watch",
    "start": "node server.js",
    "dev": "concurrently \"npm run watch:css\" \"nodemon server.js\""
  },
  "dependencies": {
    "ejs": "^3.1.10",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4"
  }
}
