<%- include('partials/head', { title: 'About Us' }) %>
<body class="font-body bg-cream overflow-x-hidden">

<%- include('partials/nav') %>

<!-- Page Hero -->
<section class="page-hero">
  <div class="absolute inset-0 hero-pattern opacity-20"></div>
  <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full bg-gold-500/10 blur-3xl"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
    <span class="section-label text-gold-400"><%= t.about_hero_label %></span>
    <h1 class="font-display text-5xl md:text-6xl font-bold text-white mt-2 mb-4"><%= t.about_hero_h_pre %> <em class="text-gold-400">Butemine</em></h1>
    <p class="text-white/70 text-lg max-w-2xl mx-auto"><%= t.about_hero_sub %></p>
  </div>
</section>

<!-- Vision & Mission -->
<section class="py-24 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-20">
      <div class="card reveal border-l-4 border-l-terracotta-500">
        <div class="w-12 h-12 bg-terracotta-50 rounded-xl flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-terracotta-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
          </svg>
        </div>
        <h2 class="font-display text-2xl font-bold text-bark mb-4"><%= t.about_vision_title %></h2>
        <p class="text-bark/80 leading-relaxed"><%= t.about_vision_body %></p>
      </div>

      <div class="card reveal border-l-4 border-l-gold-500">
        <div class="w-12 h-12 bg-gold-50 rounded-xl flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-gold-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
        </div>
        <h2 class="font-display text-2xl font-bold text-bark mb-4"><%= t.about_mission_title %></h2>
        <p class="text-bark/80 leading-relaxed"><%= t.about_mission_body %></p>
      </div>
    </div>

    <!-- Our Story -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-24">
      <div class="reveal">
        <span class="section-label"><%= t.about_story_label %></span>
        <h2 class="section-title mb-5"><%= t.about_story_h %><br /><em class="text-terracotta-500"><%= t.about_story_h_em %></em></h2>
        <div class="gold-divider mb-6"></div>
        <p class="text-bark/80 leading-relaxed mb-4"><%- t.about_story_p1 %></p>
        <p class="text-bark/80 leading-relaxed mb-4"><%- t.about_story_p2 %></p>
        <p class="text-bark/80 leading-relaxed mb-6"><%- t.about_story_p3 %></p>
        <blockquote class="border-l-4 border-gold-500 pl-5 mb-8 bg-gold-50 py-4 pr-4 rounded-r-xl">
          <p class="font-display text-lg italic text-bark/90"><%= t.about_story_quote %></p>
          <footer class="text-sm text-gold-600 mt-2 font-semibold"><%= t.about_story_founder %></footer>
        </blockquote>
      </div>

      <div class="reveal">
        <div class="space-y-6">
          <% [
            [t.about_timeline_y1, t.about_timeline_t1, t.about_timeline_d1],
            [t.about_timeline_y2, t.about_timeline_t2, t.about_timeline_d2],
            [t.about_timeline_y3, t.about_timeline_t3, t.about_timeline_d3],
            [t.about_timeline_y4, t.about_timeline_t4, t.about_timeline_d4],
          ].forEach(([year, title, desc]) => { %>
          <div class="flex gap-5">
            <div class="flex flex-col items-center">
              <div class="w-10 h-10 rounded-full bg-terracotta-500 text-white text-xs font-bold flex items-center justify-center shrink-0"><%= year.length > 4 ? '•' : year %></div>
              <div class="w-0.5 h-full bg-terracotta-100 mt-2"></div>
            </div>
            <div class="pb-6">
              <p class="text-xs text-gold-600 font-semibold uppercase tracking-widest mb-1"><%= year %></p>
              <h4 class="font-display font-bold text-bark text-lg mb-1"><%= title %></h4>
              <p class="text-bark/75 text-sm leading-relaxed"><%= desc %></p>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- Batemi Tribe & Culture -->
    <div class="rounded-3xl overflow-hidden reveal" style="background: linear-gradient(135deg, #2E5C28 0%, #1E3A19 100%);">
      <div class="p-10 md:p-14">
        <div class="max-w-4xl">
          <span class="section-label text-gold-400"><%= t.about_culture_label %></span>
          <h2 class="text-3xl md:text-4xl font-display font-bold text-white mb-5"><%= t.about_culture_h %> <em class="text-gold-400"><%= t.about_culture_h_em %></em></h2>
          <div class="gold-divider mb-6"></div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-white/85 text-sm leading-relaxed">
            <div>
              <h4 class="font-semibold text-gold-400 mb-3 font-display text-base"><%= t.about_culture_col1_title %></h4>
              <p><%= t.about_culture_col1_body %></p>
            </div>
            <div>
              <h4 class="font-semibold text-gold-400 mb-3 font-display text-base"><%= t.about_culture_col2_title %></h4>
              <p><%= t.about_culture_col2_body %></p>
            </div>
            <div>
              <h4 class="font-semibold text-gold-400 mb-3 font-display text-base"><%= t.about_culture_col3_title %></h4>
              <p><%= t.about_culture_col3_body %></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Values -->
<section class="py-16 bg-terracotta-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 reveal">
      <span class="section-label"><%= t.about_values_label %></span>
      <h2 class="section-title"><%= t.about_values_h %> <em class="text-terracotta-500"><%= t.about_values_h_em %></em></h2>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      <% [
        [t.about_value1_title, t.about_value1_desc],
        [t.about_value2_title, t.about_value2_desc],
        [t.about_value3_title, t.about_value3_desc],
        [t.about_value4_title, t.about_value4_desc],
      ].forEach(([val, desc]) => { %>
      <div class="text-center p-6 reveal">
        <div class="w-12 h-12 bg-terracotta-500 rounded-2xl mx-auto mb-4"></div>
        <h4 class="font-display font-bold text-bark mb-2"><%= val %></h4>
        <p class="text-bark/75 text-sm leading-relaxed"><%= desc %></p>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-20 bg-cream">
  <div class="max-w-3xl mx-auto px-4 text-center reveal">
    <h2 class="section-title mb-5"><%= t.about_cta_h %><br /><em class="text-terracotta-500"><%= t.about_cta_h_em %></em></h2>
    <p class="text-bark/75 mb-8 text-lg"><%= t.about_cta_body %></p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/admissions" class="btn-primary"><%= t.about_cta_btn_apply %></a>
      <a href="/contact" class="btn-outline-dark"><%= t.about_cta_btn_contact %></a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
