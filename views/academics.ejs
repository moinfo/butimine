<%- include('partials/head', { title: 'Academics' }) %>
<body class="font-body bg-cream overflow-x-hidden">

<%- include('partials/nav') %>

<!-- Page Hero -->
<section class="page-hero">
  <div class="absolute inset-0 hero-pattern opacity-20"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
    <span class="section-label text-gold-400">ACADEMICS</span>
    <h1 class="font-display text-5xl md:text-6xl font-bold text-white mt-2 mb-4">Academic <em class="text-gold-400">Programme</em></h1>
    <p class="text-white/70 text-lg max-w-2xl mx-auto">School calendar, term dates, examination schedule and academic results for Butemine English Medium Pre & Primary School.</p>
  </div>
</section>

<!-- Quick links -->
<section class="py-8 bg-white border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="#calendar"  class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-terracotta-50 border border-terracotta-200 text-terracotta-700 text-sm font-semibold hover:bg-terracotta-500 hover:text-white transition-all">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Academic Calendar
      </a>
      <a href="#exams" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-forest-50 border border-forest-200 text-forest-700 text-sm font-semibold hover:bg-forest-600 hover:text-white transition-all">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        Exam Schedule
      </a>
      <a href="/results" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-gold-50 border border-gold-200 text-gold-700 text-sm font-semibold hover:bg-gold-500 hover:text-white transition-all">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        View PSLE Results
      </a>
    </div>
  </div>
</section>

<!-- Academic Calendar -->
<section id="calendar" class="py-20 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-14 reveal">
      <span class="section-label">SCHOOL YEAR 2025</span>
      <h2 class="section-title">Academic <em class="text-terracotta-500">Calendar</em></h2>
      <div class="gold-divider mx-auto mt-5"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <!-- Term 1 -->
      <div class="card reveal p-0 overflow-hidden">
        <div class="bg-terracotta-500 px-6 py-5">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-terracotta-200 text-xs font-bold uppercase tracking-widest mb-1">Term 1</p>
              <h3 class="font-display text-2xl font-bold text-white">January – April</h3>
            </div>
            <div class="w-12 h-12 bg-white/20 rounded-2xl flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 3v1m0 16v1M4.22 4.22l.707.707M18.364 18.364l.707.707M3 12H2m20 0h-1M4.927 19.073l.707-.707M18.364 5.636l.707-.707"/><circle cx="12" cy="12" r="4"/></svg>
            </div>
          </div>
        </div>
        <div class="divide-y divide-gray-100">
          <% [
            { date: 'Jan 6',       label: 'Schools Open: Term 1 Begins',     type: 'open'    },
            { date: 'Jan 13',      label: 'New Students Orientation',          type: 'event'   },
            { date: 'Feb 17–21',   label: 'Mid-Term Break',                    type: 'break'   },
            { date: 'Mar 14',      label: 'Parent–Teacher Meeting',            type: 'event'   },
            { date: 'Apr 4–11',    label: 'End of Term 1 Examinations',        type: 'exam'    },
            { date: 'Apr 12',      label: 'Schools Close: Term 1 Ends',       type: 'close'   },
            { date: 'Apr 13 – May 4', label: 'Term 1 Holiday',               type: 'holiday' },
          ].forEach(e => { %>
          <div class="flex items-start gap-4 px-5 py-3.5">
            <div class="shrink-0 w-20 text-xs font-bold text-bark/50 pt-0.5"><%= e.date %></div>
            <div class="flex items-center gap-2 flex-1">
              <span class="w-2 h-2 rounded-full shrink-0 <%=
                e.type === 'open'    ? 'bg-forest-500' :
                e.type === 'close'   ? 'bg-terracotta-500' :
                e.type === 'exam'    ? 'bg-gold-500' :
                e.type === 'break'   ? 'bg-blue-400' :
                e.type === 'holiday' ? 'bg-purple-400' :
                'bg-bark/30'
              %>"></span>
              <p class="text-sm text-bark font-medium"><%= e.label %></p>
            </div>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- Term 2 -->
      <div class="card reveal p-0 overflow-hidden">
        <div class="bg-forest-700 px-6 py-5">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-forest-300 text-xs font-bold uppercase tracking-widest mb-1">Term 2</p>
              <h3 class="font-display text-2xl font-bold text-white">May – August</h3>
            </div>
            <div class="w-12 h-12 bg-white/20 rounded-2xl flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3 17l4-8 4 4 4-6 4 10"/></svg>
            </div>
          </div>
        </div>
        <div class="divide-y divide-gray-100">
          <% [
            { date: 'May 5',       label: 'Schools Open: Term 2 Begins',     type: 'open'    },
            { date: 'Jun 16',      label: 'Nane Nane / Public Holiday',        type: 'holiday' },
            { date: 'Jun 23–27',   label: 'Mid-Term Break',                    type: 'break'   },
            { date: 'Jul 7',       label: 'Sports Day',                        type: 'event'   },
            { date: 'Jul 18',      label: 'Talent Show & Cultural Day',        type: 'event'   },
            { date: 'Aug 1–8',     label: 'End of Term 2 Examinations',        type: 'exam'    },
            { date: 'Aug 9',       label: 'Schools Close: Term 2 Ends',       type: 'close'   },
            { date: 'Aug 10 – Sep 1', label: 'Term 2 Holiday',               type: 'holiday' },
          ].forEach(e => { %>
          <div class="flex items-start gap-4 px-5 py-3.5">
            <div class="shrink-0 w-20 text-xs font-bold text-bark/50 pt-0.5"><%= e.date %></div>
            <div class="flex items-center gap-2 flex-1">
              <span class="w-2 h-2 rounded-full shrink-0 <%=
                e.type === 'open'    ? 'bg-forest-500' :
                e.type === 'close'   ? 'bg-terracotta-500' :
                e.type === 'exam'    ? 'bg-gold-500' :
                e.type === 'break'   ? 'bg-blue-400' :
                e.type === 'holiday' ? 'bg-purple-400' :
                'bg-bark/30'
              %>"></span>
              <p class="text-sm text-bark font-medium"><%= e.label %></p>
            </div>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- Term 3 -->
      <div class="card reveal p-0 overflow-hidden">
        <div class="bg-bark px-6 py-5">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-gold-400 text-xs font-bold uppercase tracking-widest mb-1">Term 3</p>
              <h3 class="font-display text-2xl font-bold text-white">Sep – December</h3>
            </div>
            <div class="w-12 h-12 bg-white/20 rounded-2xl flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/></svg>
            </div>
          </div>
        </div>
        <div class="divide-y divide-gray-100">
          <% [
            { date: 'Sep 2',       label: 'Schools Open: Term 3 Begins',     type: 'open'    },
            { date: 'Oct 6–10',    label: 'PSLE National Examinations',        type: 'exam'    },
            { date: 'Oct 13–17',   label: 'Mid-Term Break',                    type: 'break'   },
            { date: 'Nov 3–14',    label: 'End of Year Examinations (Std 1–6)',type: 'exam'    },
            { date: 'Nov 21',      label: 'Graduation & Prize Giving Ceremony',type: 'event'   },
            { date: 'Nov 28',      label: 'Community Outreach Day',            type: 'event'   },
            { date: 'Dec 5',       label: 'Schools Close: End of Year',       type: 'close'   },
            { date: 'Dec 6 – Jan 5', label: 'Long Holiday',                  type: 'holiday' },
          ].forEach(e => { %>
          <div class="flex items-start gap-4 px-5 py-3.5">
            <div class="shrink-0 w-20 text-xs font-bold text-bark/50 pt-0.5"><%= e.date %></div>
            <div class="flex items-center gap-2 flex-1">
              <span class="w-2 h-2 rounded-full shrink-0 <%=
                e.type === 'open'    ? 'bg-forest-500' :
                e.type === 'close'   ? 'bg-terracotta-500' :
                e.type === 'exam'    ? 'bg-gold-500' :
                e.type === 'break'   ? 'bg-blue-400' :
                e.type === 'holiday' ? 'bg-purple-400' :
                'bg-bark/30'
              %>"></span>
              <p class="text-sm text-bark font-medium"><%= e.label %></p>
            </div>
          </div>
          <% }) %>
        </div>
      </div>

    </div>

    <!-- Legend -->
    <div class="mt-8 flex flex-wrap gap-4 justify-center reveal">
      <% [
        { color: 'bg-forest-500',    label: 'Schools Open / Close' },
        { color: 'bg-terracotta-500',label: 'Schools Close' },
        { color: 'bg-gold-500',      label: 'Examinations' },
        { color: 'bg-blue-400',      label: 'Mid-Term Break' },
        { color: 'bg-purple-400',    label: 'Holidays' },
        { color: 'bg-bark/30',       label: 'School Events' },
      ].forEach(l => { %>
      <div class="flex items-center gap-2 text-xs text-bark/60">
        <span class="w-2.5 h-2.5 rounded-full <%= l.color %>"></span>
        <%= l.label %>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- Exam Schedule -->
<section id="exams" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-14 reveal">
      <span class="section-label">EXAMINATION SCHEDULE</span>
      <h2 class="section-title">Internal & National <em class="text-terracotta-500">Examinations</em></h2>
      <div class="gold-divider mx-auto mt-5"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">

      <!-- Internal Exams -->
      <div class="card reveal">
        <h3 class="font-display text-xl font-bold text-bark mb-6 flex items-center gap-3">
          <span class="w-10 h-10 bg-terracotta-100 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-terracotta-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2"/></svg>
          </span>
          Internal School Examinations
        </h3>
        <div class="space-y-4">
          <% [
            { name: 'Mid-Term Assessment',   classes: 'Standard 1 – 7', period: 'Feb, Jun, Oct',    marks: 'Per Subject',  note: '' },
            { name: 'End-of-Term Examination', classes: 'Standard 1 – 6', period: 'Apr, Aug, Nov',  marks: 'Per Subject',  note: 'Graded & reported to parents' },
            { name: 'Mock PSLE Examination', classes: 'Standard 7',       period: 'August',          marks: 'Out of 300',   note: 'Preparation for national exam' },
            { name: 'Annual Prize Giving',   classes: 'All Standards',    period: 'November',        marks: '—',            note: 'Top performers awarded' },
          ].forEach(ex => { %>
          <div class="bg-cream rounded-xl p-4 border border-terracotta-100">
            <div class="flex items-start justify-between gap-4 mb-2">
              <h4 class="font-semibold text-bark text-sm"><%= ex.name %></h4>
              <span class="shrink-0 text-xs bg-terracotta-100 text-terracotta-700 font-bold px-2 py-0.5 rounded-full"><%= ex.period %></span>
            </div>
            <p class="text-xs text-bark/60"><%= ex.classes %> · <%= ex.marks %></p>
            <% if (ex.note) { %><p class="text-xs text-bark/40 mt-1 italic"><%= ex.note %></p><% } %>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- National Exams -->
      <div class="card reveal">
        <h3 class="font-display text-xl font-bold text-bark mb-6 flex items-center gap-3">
          <span class="w-10 h-10 bg-forest-100 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-forest-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          </span>
          National Examinations (NECTA)
        </h3>
        <div class="space-y-4">
          <% [
            { name: 'PSLE (Primary School Leaving Exam)', classes: 'Standard 7', period: 'October', marks: 'Out of 300', note: 'Administered by NECTA. Results determine secondary school placement.' },
          ].forEach(ex => { %>
          <div class="bg-forest-50 rounded-xl p-5 border border-forest-200">
            <div class="flex items-start justify-between gap-4 mb-2">
              <h4 class="font-semibold text-bark"><%= ex.name %></h4>
              <span class="shrink-0 text-xs bg-forest-600 text-white font-bold px-2 py-0.5 rounded-full"><%= ex.period %></span>
            </div>
            <p class="text-sm text-bark/60 mb-2"><%= ex.classes %> · <%= ex.marks %></p>
            <p class="text-xs text-bark/50 italic"><%= ex.note %></p>
          </div>
          <% }) %>

          <!-- PSLE Subjects -->
          <div class="bg-gold-50 rounded-xl p-5 border border-gold-200">
            <h4 class="font-semibold text-bark text-sm mb-3">PSLE Subjects (7 subjects)</h4>
            <div class="grid grid-cols-2 gap-2">
              <% ['Kiswahili', 'English Language', 'Mathematics', 'Science', 'Social Studies', 'Civics & Ethics', 'Maarifa (General Knowledge)'].forEach(s => { %>
              <div class="flex items-center gap-2 text-xs text-bark/70">
                <span class="w-1.5 h-1.5 bg-gold-500 rounded-full"></span>
                <%= s %>
              </div>
              <% }) %>
            </div>
          </div>

          <div class="bg-bark/5 rounded-xl p-4 border border-bark/10">
            <p class="text-xs text-bark/60 leading-relaxed">
              <strong class="text-bark">Grading:</strong> A (250–300) · B (200–249) · C (150–199) · D (100–149) · E (0–99)<br/>
              Results are published by NECTA at <span class="text-terracotta-600 font-medium">necta.go.tz</span>
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA to Results page -->
    <div class="card reveal bg-bark text-center py-10">
      <h3 class="font-display text-2xl font-bold text-white mb-2">View Our PSLE Results</h3>
      <p class="text-white/60 text-sm mb-6">Butemine has achieved 100% pass rate every year since 2021, including <strong class="text-gold-400">#1 in Ngorongoro District</strong> in 2021 and 2022.</p>
      <a href="/results" class="btn-gold">See Full Academic Results</a>
    </div>

  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
