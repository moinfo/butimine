<%- include('../partials/head', { title: 'Admin Login' }) %>
<body class="font-body bg-cream flex items-center justify-center min-h-screen">

  <div class="bg-white rounded-2xl shadow-lg p-10 w-full max-w-sm border border-terracotta-100">
    <div class="text-center mb-8">
      <img src="/logo.png" alt="Butemine School" class="h-14 w-14 mx-auto mb-4 rounded-full bg-bark/5 p-1" />
      <h1 class="font-display text-2xl font-bold text-bark">Admin Login</h1>
      <p class="text-bark/50 text-sm mt-1">Butemine School — News Manager</p>
    </div>

    <% if (error) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-xl px-4 py-3 mb-5"><%= error %></div>
    <% } %>

    <form method="POST" action="/admin/login" class="space-y-4">
      <div>
        <label class="block text-xs font-semibold text-bark/70 uppercase tracking-widest mb-2" for="password">Password</label>
        <input type="password" id="password" name="password" required autofocus
               class="w-full border border-terracotta-200 rounded-xl px-4 py-3 text-sm text-bark bg-cream focus:outline-none focus:ring-2 focus:ring-terracotta-500 focus:border-transparent" />
      </div>
      <button type="submit" class="btn-primary w-full text-center">Sign In</button>
    </form>
  </div>

</body>
</html>
