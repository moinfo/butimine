<%- include('../partials/head', { title: 'Manage News' }) %>
<body class="font-body bg-cream min-h-screen">

  <!-- Admin bar -->
  <div class="bg-bark text-white px-6 py-4 flex items-center justify-between sticky top-0 z-50 shadow-lg">
    <div class="flex items-center gap-3">
      <img src="/logo.png" alt="Butemine" class="h-8 w-8 rounded-full bg-white/10 p-0.5" />
      <span class="font-display font-bold text-base">News Manager</span>
    </div>
    <div class="flex items-center gap-5 text-sm">
      <a href="/news" target="_blank" class="text-white/60 hover:text-gold-400 transition-colors">View Page ↗</a>
      <a href="/admin/logout" class="text-white/60 hover:text-red-400 transition-colors">Logout</a>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-4 py-10">

    <% if (saved) { %>
    <div class="bg-green-50 border border-green-200 text-green-700 text-sm rounded-xl px-5 py-3 mb-8 flex items-center gap-2">
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/></svg>
      Article published successfully.
    </div>
    <% } %>

    <!-- Add Article -->
    <div class="bg-white rounded-2xl border border-terracotta-100 shadow-sm p-8 mb-10">
      <h2 class="font-display text-xl font-bold text-bark mb-6">Add New Article</h2>
      <form method="POST" action="/admin/news/add" class="space-y-5">

        <div>
          <label class="block text-xs font-semibold text-bark/70 uppercase tracking-widest mb-2">Title *</label>
          <input type="text" name="title" required
                 class="w-full border border-terracotta-200 rounded-xl px-4 py-3 text-sm text-bark bg-cream focus:outline-none focus:ring-2 focus:ring-terracotta-500 focus:border-transparent" />
        </div>

        <div class="grid grid-cols-2 gap-5">
          <div>
            <label class="block text-xs font-semibold text-bark/70 uppercase tracking-widest mb-2">Date *</label>
            <div class="flex gap-2">
              <select name="month" required
                      class="flex-1 border border-terracotta-200 rounded-xl px-3 py-3 text-sm text-bark bg-cream focus:outline-none focus:ring-2 focus:ring-terracotta-500 focus:border-transparent">
                <% ['January','February','March','April','May','June','July','August','September','October','November','December'].forEach((m, i) => { %>
                <option value="<%= m %>"><%= m %></option>
                <% }) %>
              </select>
              <select name="year" required
                      class="w-24 border border-terracotta-200 rounded-xl px-3 py-3 text-sm text-bark bg-cream focus:outline-none focus:ring-2 focus:ring-terracotta-500 focus:border-transparent">
                <% for (let y = new Date().getFullYear() + 1; y >= 2020; y--) { %>
                <option value="<%= y %>" <%= y === new Date().getFullYear() ? 'selected' : '' %>><%= y %></option>
                <% } %>
              </select>
            </div>
          </div>
          <div>
            <label class="block text-xs font-semibold text-bark/70 uppercase tracking-widest mb-2">Category *</label>
            <select name="category" required
                    class="w-full border border-terracotta-200 rounded-xl px-4 py-3 text-sm text-bark bg-cream focus:outline-none focus:ring-2 focus:ring-terracotta-500 focus:border-transparent">
              <option value="Academic">Academic</option>
              <option value="Events">Events</option>
              <option value="Community">Community</option>
              <option value="Volunteers">Volunteers</option>
              <option value="Support">Support</option>
              <option value="Milestone">Milestone</option>
            </select>
          </div>
        </div>

        <div>
          <label class="block text-xs font-semibold text-bark/70 uppercase tracking-widest mb-2">Excerpt *</label>
          <textarea name="excerpt" rows="4" required
                    class="w-full border border-terracotta-200 rounded-xl px-4 py-3 text-sm text-bark bg-cream focus:outline-none focus:ring-2 focus:ring-terracotta-500 focus:border-transparent resize-none"></textarea>
        </div>

        <div class="flex items-end gap-6">
          <div class="flex-1">
            <label class="block text-xs font-semibold text-bark/70 uppercase tracking-widest mb-2">Card Colour</label>
            <select name="color"
                    class="w-full border border-terracotta-200 rounded-xl px-4 py-3 text-sm text-bark bg-cream focus:outline-none focus:ring-2 focus:ring-terracotta-500 focus:border-transparent">
              <option value="terracotta">Blue</option>
              <option value="gold">Green</option>
              <option value="forest">Dark Green</option>
            </select>
          </div>
          <label class="flex items-center gap-3 cursor-pointer pb-3">
            <input type="checkbox" name="featured" class="w-5 h-5 rounded accent-terracotta-500" />
            <span class="text-sm font-semibold text-bark/70">Mark as Featured</span>
          </label>
        </div>

        <button type="submit" class="btn-primary">Publish Article</button>
      </form>
    </div>

    <!-- Article List -->
    <div class="flex items-center justify-between mb-5">
      <h2 class="font-display text-xl font-bold text-bark">All Articles</h2>
      <span class="text-bark/40 text-sm"><%= newsItems.length %> total</span>
    </div>

    <% if (newsItems.length === 0) { %>
    <div class="text-center text-bark/40 py-16 bg-white rounded-2xl border border-terracotta-100">No articles yet. Add one above.</div>
    <% } %>

    <div class="space-y-3">
      <% newsItems.forEach((item, i) => { %>
      <div class="bg-white rounded-xl border border-terracotta-100 px-6 py-5 flex items-start justify-between gap-4 shadow-sm">
        <div class="flex-1 min-w-0">
          <div class="flex flex-wrap items-center gap-2 mb-1.5">
            <span class="text-xs font-bold bg-terracotta-100 text-terracotta-700 px-2 py-0.5 rounded-full"><%= item.category %></span>
            <span class="text-xs text-bark/40"><%= item.date %></span>
            <% if (item.featured) { %>
            <span class="text-xs font-bold bg-gold-100 text-gold-700 px-2 py-0.5 rounded-full">Featured</span>
            <% } %>
          </div>
          <p class="font-display font-bold text-bark text-base leading-snug"><%= item.title %></p>
          <p class="text-bark/55 text-sm mt-1 line-clamp-2"><%= item.excerpt %></p>
        </div>
        <div class="flex gap-2 shrink-0">
          <a href="/admin/news/edit/<%= i %>"
             class="text-xs font-semibold text-terracotta-600 hover:text-white border border-terracotta-200 hover:bg-terracotta-500 hover:border-terracotta-500 px-3 py-1.5 rounded-lg transition-all">
            Edit
          </a>
          <form method="POST" action="/admin/news/delete/<%= i %>"
                onsubmit="return confirm('Delete this article?')">
            <button type="submit"
                    class="text-xs font-semibold text-red-500 hover:text-white border border-red-200 hover:bg-red-500 hover:border-red-500 px-3 py-1.5 rounded-lg transition-all">
              Delete
            </button>
          </form>
        </div>
      </div>
      <% }) %>
    </div>

  </div>
</body>
</html>
