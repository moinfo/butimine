<%- include('partials/head', { title: 'Admissions' }) %>
<body class="font-body bg-cream overflow-x-hidden">

<%- include('partials/nav') %>

<!-- Page Hero -->
<section class="page-hero">
  <div class="absolute inset-0 hero-pattern opacity-20"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
    <span class="section-label text-gold-400">Enrol Your Child</span>
    <h1 class="font-display text-5xl md:text-6xl font-bold text-white mt-2 mb-4">Admissions</h1>
    <p class="text-white/70 text-lg max-w-2xl mx-auto">Begin your child's journey towards becoming an agent of change. We welcome families from all backgrounds.</p>
  </div>
</section>

<!-- Programs -->
<section class="py-24 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-16 reveal">
      <span class="section-label">Available Programs</span>
      <h2 class="section-title">Find the Right <em class="text-terracotta-500">Program</em></h2>
      <div class="gold-divider mx-auto mt-5"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
      <% [
        { name: 'Daycare Centre', ages: 'Ages 0 – 3', location: 'All 3 Centres', desc: 'Safe, nurturing childcare with developmental activities. Available at Samunge HQ, Sale Branch, and Jema Branch — bringing early care close to every family.', color: 'terracotta' },
        { name: 'Nursery / Pre-school', ages: 'Ages 3 – 6', location: 'All 3 Centres', desc: 'Play-based learning preparing children for formal schooling. Offered at Samunge HQ, Sale Branch and Jema Branch. Focus on language, numeracy, social skills and creative expression.', color: 'gold' },
        { name: 'Primary School', ages: 'Standard 1 – 7', location: 'Samunge HQ Only', desc: 'Full Tanzania national curriculum in English medium, exclusively at Samunge HQ. Students prepare for National Standard 4 and Standard 7 examinations.', color: 'forest' },
      ].forEach(prog => { %>
      <div class="card reveal text-center">
        <div class="w-16 h-16 rounded-2xl bg-<%= prog.color %>-50 border-2 border-<%= prog.color %>-200 mx-auto mb-5 flex items-center justify-center">
          <svg class="w-8 h-8 text-<%= prog.color %>-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M12 14l9-5-9-5-9 5 9 5z"/><path d="M12 14l6.16-3.422a12.083 12.083 0 0 1 .665 6.479A11.952 11.952 0 0 0 12 20.055a11.952 11.952 0 0 0-6.824-2.998 12.078 12.078 0 0 1 .665-6.479L12 14z"/>
          </svg>
        </div>
        <span class="inline-block bg-<%= prog.color %>-100 text-<%= prog.color %>-700 text-xs font-bold px-3 py-1 rounded-full mb-3"><%= prog.ages %></span>
        <h3 class="font-display text-xl font-bold text-bark mb-1"><%= prog.name %></h3>
        <p class="text-gold-600 text-xs uppercase tracking-widest font-semibold mb-4"><%= prog.location %></p>
        <p class="text-bark/70 text-sm leading-relaxed"><%= prog.desc %></p>
      </div>
      <% }) %>
    </div>

    <!-- How to Apply -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <div class="reveal">
        <span class="section-label">Step by Step</span>
        <h2 class="section-title mb-8">How to <em class="text-terracotta-500">Apply</em></h2>

        <div class="space-y-6">
          <% [
            ['Contact the School', 'Reach out by phone to speak with our admissions team. We will provide you with the current joining instruction form and answer any questions.', 'Call: +255 788 384 699'],
            ['Complete the Application Form', 'Fill in the official Joining Instruction Form. Ensure all sections are completed accurately, including the student\'s full name, date of birth, and guardian details.', 'Form available on request'],
            ['Submit Required Documents', 'Submit the completed form along with required documents (birth certificate, previous school reports if applicable, and parent/guardian ID).', 'See requirements list →'],
            ['Pay Registration Fees', 'Process payment via our school bank account. Bring the payment receipt to the school office as confirmation of your application.', 'Bank account provided on request'],
            ['Admission Confirmed', 'Upon review, we will confirm your child\'s placement and provide details on the school uniform, start date, and supplies needed.', 'Welcome to Butemine!'],
          ].forEach(([title, desc, note], i) => { %>
          <div class="flex gap-5">
            <div class="w-10 h-10 rounded-full bg-terracotta-500 text-white font-bold text-sm flex items-center justify-center shrink-0 mt-0.5">
              <%= i + 1 %>
            </div>
            <div>
              <h4 class="font-display font-bold text-bark text-lg mb-1"><%= title %></h4>
              <p class="text-bark/70 text-sm leading-relaxed mb-1"><%= desc %></p>
              <span class="text-xs text-gold-600 font-semibold"><%= note %></span>
            </div>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- Requirements & Fees -->
      <div class="space-y-8">
        <!-- Requirements -->
        <div class="card reveal">
          <h3 class="font-display text-xl font-bold text-bark mb-5">Requirements</h3>
          <ul class="space-y-3">
            <% [
              'Completed Joining Instruction Form',
              'Child\'s Birth Certificate (original + copy)',
              'Parent/Guardian National ID (copy)',
              'Recent passport-size photograph (2 copies)',
              'Previous school report (if transferring)',
              'Health/immunisation record',
            ].forEach(req => { %>
            <li class="flex items-start gap-3 text-sm text-bark/80">
              <svg class="w-5 h-5 text-forest-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <%= req %>
            </li>
            <% }) %>
          </ul>
        </div>

        <!-- School Fees Notice -->
        <div class="card reveal border-l-4 border-l-gold-500 bg-gold-50">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 text-gold-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <div>
              <h4 class="font-display font-semibold text-bark mb-2">School Fees</h4>
              <p class="text-bark/70 text-sm leading-relaxed">Current school fees and payment schedules are provided during the admissions process. Please contact us directly for the most up-to-date fee structure.</p>
              <p class="text-sm text-gold-700 font-medium mt-2">⭐ 63 students currently attend with full fee support for those unable to pay.</p>
            </div>
          </div>
        </div>

        <!-- Uniform Notice -->
        <div class="card reveal">
          <h3 class="font-display text-xl font-bold text-bark mb-3">School Uniform</h3>
          <p class="text-bark/70 text-sm leading-relaxed mb-4">All students are required to wear the Butemine School uniform. Uniform specifications and approved suppliers will be provided upon admission confirmation.</p>
          <a href="/contact" class="inline-flex items-center gap-2 text-terracotta-500 text-sm font-semibold hover:gap-3 transition-all">
            Enquire about uniform details
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Inclusive Admissions Banner -->
<section class="py-16 bg-bark relative overflow-hidden">
  <div class="absolute inset-0 hero-pattern opacity-10"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center reveal">
    <h2 class="font-display text-3xl md:text-4xl text-white font-bold mb-4">No Child is Turned Away</h2>
    <p class="text-white/70 text-lg mb-8 max-w-2xl mx-auto">Our commitment to inclusive education means we work with families who cannot afford fees. Financial hardship should never be a barrier to learning.</p>
    <a href="/contact" class="btn-gold">Speak With Our Team</a>
  </div>
</section>

<!-- Contact CTA -->
<section class="py-16 bg-cream">
  <div class="max-w-3xl mx-auto px-4 text-center reveal">
    <h3 class="font-display text-2xl font-bold text-bark mb-3">Ready to Enrol?</h3>
    <p class="text-bark/70 mb-6">Contact us to receive the application form and begin the admissions process.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="tel:+255788384699" class="btn-primary flex items-center justify-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.21 3.18 2 2 0 0 1 3.22 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16z"/></svg>
        Call Us Now
      </a>
      <a href="/contact" class="btn-outline-dark">Send a Message</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
