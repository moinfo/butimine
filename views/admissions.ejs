<%- include('partials/head', { title: 'Admissions' }) %>
<body class="font-body bg-cream overflow-x-hidden">

<%- include('partials/nav') %>

<!-- Page Hero -->
<section class="page-hero">
  <div class="absolute inset-0 hero-pattern opacity-20"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
    <span class="section-label text-gold-400"><%= t.admissions_hero_label %></span>
    <h1 class="font-display text-5xl md:text-6xl font-bold text-white mt-2 mb-4"><%= t.admissions_hero_title %></h1>
    <p class="text-white/70 text-lg max-w-2xl mx-auto"><%= t.admissions_hero_sub %></p>
  </div>
</section>

<!-- Programs -->
<section class="py-24 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-16 reveal">
      <span class="section-label"><%= t.admissions_programs_label %></span>
      <h2 class="section-title"><%= t.admissions_programs_h %> <em class="text-terracotta-500"><%= t.admissions_programs_h_em %></em></h2>
      <div class="gold-divider mx-auto mt-5"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
      <% [
        { name: t.adm_prog1_name, ages: t.adm_prog1_ages, loc: t.adm_prog1_loc, desc: t.adm_prog1_desc, color: 'terracotta' },
        { name: t.adm_prog2_name, ages: t.adm_prog2_ages, loc: t.adm_prog2_loc, desc: t.adm_prog2_desc, color: 'gold' },
        { name: t.adm_prog3_name, ages: t.adm_prog3_ages, loc: t.adm_prog3_loc, desc: t.adm_prog3_desc, color: 'forest' },
      ].forEach(prog => { %>
      <div class="card reveal text-center">
        <div class="w-16 h-16 rounded-2xl bg-<%= prog.color %>-50 border-2 border-<%= prog.color %>-200 mx-auto mb-5 flex items-center justify-center">
          <svg class="w-8 h-8 text-<%= prog.color %>-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M12 14l9-5-9-5-9 5 9 5z"/><path d="M12 14l6.16-3.422a12.083 12.083 0 0 1 .665 6.479A11.952 11.952 0 0 0 12 20.055a11.952 11.952 0 0 0-6.824-2.998 12.078 12.078 0 0 1 .665-6.479L12 14z"/>
          </svg>
        </div>
        <span class="inline-block bg-<%= prog.color %>-100 text-<%= prog.color %>-700 text-xs font-bold px-3 py-1 rounded-full mb-3"><%= prog.ages %></span>
        <h3 class="font-display text-xl font-bold text-bark mb-1"><%= prog.name %></h3>
        <p class="text-gold-600 text-xs uppercase tracking-widest font-semibold mb-4"><%= prog.loc %></p>
        <p class="text-bark/75 text-sm leading-relaxed"><%= prog.desc %></p>
      </div>
      <% }) %>
    </div>

    <!-- How to Apply -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <div class="reveal">
        <span class="section-label"><%= t.admissions_apply_label %></span>
        <h2 class="section-title mb-8"><%= t.admissions_apply_h %> <em class="text-terracotta-500"><%= t.admissions_apply_h_em %></em></h2>

        <div class="space-y-6">
          <% [
            [t.adm_step1_title, t.adm_step1_desc, t.adm_step1_note],
            [t.adm_step2_title, t.adm_step2_desc, t.adm_step2_note],
            [t.adm_step3_title, t.adm_step3_desc, t.adm_step3_note],
            [t.adm_step4_title, t.adm_step4_desc, t.adm_step4_note],
            [t.adm_step5_title, t.adm_step5_desc, t.adm_step5_note],
          ].forEach(([title, desc, note], i) => { %>
          <div class="flex gap-5">
            <div class="w-10 h-10 rounded-full bg-terracotta-500 text-white font-bold text-sm flex items-center justify-center shrink-0 mt-0.5">
              <%= i + 1 %>
            </div>
            <div>
              <h4 class="font-display font-bold text-bark text-lg mb-1"><%= title %></h4>
              <p class="text-bark/75 text-sm leading-relaxed mb-1"><%= desc %></p>
              <span class="text-xs text-gold-600 font-semibold"><%= note %></span>
            </div>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- Requirements & Fees -->
      <div class="space-y-8">
        <!-- Requirements -->
        <div class="card reveal">
          <h3 class="font-display text-xl font-bold text-bark mb-5"><%= t.admissions_req_title %></h3>
          <ul class="space-y-3">
            <% [
              t.adm_req1, t.adm_req2, t.adm_req3,
              t.adm_req4, t.adm_req5, t.adm_req6,
            ].forEach(req => { %>
            <li class="flex items-start gap-3 text-sm text-bark/80">
              <svg class="w-5 h-5 text-forest-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <%= req %>
            </li>
            <% }) %>
          </ul>
        </div>

        <!-- School Fees Notice -->
        <div class="card reveal border-l-4 border-l-gold-500 bg-gold-50">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 text-gold-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <div>
              <h4 class="font-display font-semibold text-bark mb-2"><%= t.admissions_fees_title %></h4>
              <p class="text-bark/75 text-sm leading-relaxed"><%= t.admissions_fees_body %></p>
              <p class="text-sm text-gold-700 font-medium mt-2"><%= t.admissions_fees_note %></p>
            </div>
          </div>
        </div>

        <!-- Uniform Notice -->
        <div class="card reveal">
          <h3 class="font-display text-xl font-bold text-bark mb-3"><%= t.admissions_uniform_title %></h3>
          <p class="text-bark/75 text-sm leading-relaxed mb-4"><%= t.admissions_uniform_body %></p>
          <a href="/contact" class="inline-flex items-center gap-2 text-terracotta-500 text-sm font-semibold hover:gap-3 transition-all">
            <%= t.admissions_uniform_link %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Inclusive Admissions Banner -->
<section class="py-16 bg-bark relative overflow-hidden">
  <div class="absolute inset-0 hero-pattern opacity-10"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center reveal">
    <h2 class="font-display text-3xl md:text-4xl text-white font-bold mb-4"><%= t.admissions_nochild_title %></h2>
    <p class="text-white/80 text-lg mb-8 max-w-2xl mx-auto"><%= t.admissions_nochild_body %></p>
    <a href="/contact" class="btn-gold"><%= t.admissions_nochild_btn %></a>
  </div>
</section>

<!-- Contact CTA -->
<section class="py-16 bg-cream">
  <div class="max-w-3xl mx-auto px-4 text-center reveal">
    <h3 class="font-display text-2xl font-bold text-bark mb-3"><%= t.admissions_enrol_title %></h3>
    <p class="text-bark/75 mb-6"><%= t.admissions_enrol_body %></p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="tel:+255788384699" class="btn-primary flex items-center justify-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.21 3.18 2 2 0 0 1 3.22 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16z"/></svg>
        <%= t.admissions_btn_call %>
      </a>
      <a href="/contact" class="btn-outline-dark"><%= t.admissions_btn_msg %></a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
