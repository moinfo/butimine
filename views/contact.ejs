<%- include('partials/head', { title: 'Contact Us' }) %>
<body class="font-body bg-cream overflow-x-hidden">

<%- include('partials/nav') %>

<!-- Page Hero -->
<section class="page-hero">
  <div class="absolute inset-0 hero-pattern opacity-20"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
    <span class="section-label text-gold-400">We'd Love to Hear From You</span>
    <h1 class="font-display text-5xl md:text-6xl font-bold text-white mt-2 mb-4">Contact <em class="text-gold-400">Us</em></h1>
    <p class="text-white/70 text-lg max-w-2xl mx-auto">Reach out for admissions enquiries, volunteering opportunities, or simply to learn more about Butemine School.</p>
  </div>
</section>

<!-- Contact Section -->
<section class="py-24 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

      <!-- Contact Info -->
      <div class="lg:col-span-2 reveal">
        <span class="section-label">Get in Touch</span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-bark mb-6">We're Here<br /><em class="text-terracotta-500">to Help</em></h2>
        <div class="gold-divider mb-8"></div>

        <div class="space-y-6">
          <!-- Phone -->
          <div class="flex gap-4 items-start">
            <div class="w-11 h-11 bg-terracotta-50 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-terracotta-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.21 3.18 2 2 0 0 1 3.22 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-gold-600 font-semibold uppercase tracking-widest mb-1">Phone</p>
              <a href="tel:+255788384699" class="block text-bark font-medium hover:text-terracotta-500 transition-colors">+255 788 384 699</a>
              <a href="tel:+255788384862" class="block text-bark font-medium hover:text-terracotta-500 transition-colors">+255 788 384 862</a>
            </div>
          </div>

          <!-- Email -->
          <div class="flex gap-4 items-start">
            <div class="w-11 h-11 bg-gold-50 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-gold-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-gold-600 font-semibold uppercase tracking-widest mb-1">Email</p>
              <p class="text-bark font-medium">info@butemine.ac.tz</p>
              <p class="text-bark/50 text-xs mt-0.5">(domain coming soon)</p>
            </div>
          </div>

          <!-- Address -->
          <div class="flex gap-4 items-start">
            <div class="w-11 h-11 bg-forest-50 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-forest-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-gold-600 font-semibold uppercase tracking-widest mb-1">Address</p>
              <p class="text-bark leading-relaxed">Samunge Village, Samunge Ward<br />Sale Division, Ngorongoro District<br />Arusha Region, Tanzania</p>
            </div>
          </div>

          <!-- Website -->
          <div class="flex gap-4 items-start">
            <div class="w-11 h-11 bg-terracotta-50 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-terracotta-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-gold-600 font-semibold uppercase tracking-widest mb-1">Website</p>
              <a href="http://www.butemine.ac.tz" class="text-bark font-medium hover:text-terracotta-500 transition-colors">www.butemine.ac.tz</a>
            </div>
          </div>
        </div>

        <!-- Social Media -->
        <div class="mt-8 pt-8 border-t border-terracotta-100">
          <p class="text-xs text-gold-600 font-semibold uppercase tracking-widest mb-4">Follow Us</p>
          <div class="flex gap-3">
            <a href="https://www.facebook.com/share/1CfGeEVe3b/" target="_blank" rel="noopener noreferrer"
               class="flex items-center gap-2 bg-white border border-terracotta-100 hover:border-terracotta-300 hover:bg-terracotta-50 text-bark/70 hover:text-terracotta-500 px-4 py-2.5 rounded-xl text-sm font-medium transition-all">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              Facebook
            </a>
            <a href="https://www.instagram.com/butemineschool" target="_blank" rel="noopener noreferrer"
               class="flex items-center gap-2 bg-white border border-terracotta-100 hover:border-terracotta-300 hover:bg-terracotta-50 text-bark/70 hover:text-terracotta-500 px-4 py-2.5 rounded-xl text-sm font-medium transition-all">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
              Instagram
            </a>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="lg:col-span-3 reveal">
        <div class="card p-0 overflow-hidden">
          <div class="bg-terracotta-500 px-8 py-6">
            <h3 class="font-display text-2xl font-bold text-white">Send Us a Message</h3>
            <p class="text-white/70 text-sm mt-1">We'll respond as soon as possible.</p>
          </div>
          <form class="p-8 space-y-5" action="#" method="POST">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-xs font-semibold text-bark/70 uppercase tracking-widest mb-2" for="first-name">First Name *</label>
                <input type="text" id="first-name" name="first_name" required
                       class="w-full border border-terracotta-200 rounded-xl px-4 py-3 text-sm text-bark bg-cream focus:outline-none focus:ring-2 focus:ring-terracotta-500 focus:border-transparent transition-all" placeholder="Your first name" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-bark/70 uppercase tracking-widest mb-2" for="last-name">Last Name *</label>
                <input type="text" id="last-name" name="last_name" required
                       class="w-full border border-terracotta-200 rounded-xl px-4 py-3 text-sm text-bark bg-cream focus:outline-none focus:ring-2 focus:ring-terracotta-500 focus:border-transparent transition-all" placeholder="Your last name" />
              </div>
            </div>
            <div>
              <label class="block text-xs font-semibold text-bark/70 uppercase tracking-widest mb-2" for="email">Email Address</label>
              <input type="email" id="email" name="email"
                     class="w-full border border-terracotta-200 rounded-xl px-4 py-3 text-sm text-bark bg-cream focus:outline-none focus:ring-2 focus:ring-terracotta-500 focus:border-transparent transition-all" placeholder="your@email.com" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-bark/70 uppercase tracking-widest mb-2" for="phone">Phone Number *</label>
              <input type="tel" id="phone" name="phone" required
                     class="w-full border border-terracotta-200 rounded-xl px-4 py-3 text-sm text-bark bg-cream focus:outline-none focus:ring-2 focus:ring-terracotta-500 focus:border-transparent transition-all" placeholder="+255 700 000 000" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-bark/70 uppercase tracking-widest mb-2" for="enquiry-type">Enquiry Type</label>
              <select id="enquiry-type" name="enquiry_type"
                      class="w-full border border-terracotta-200 rounded-xl px-4 py-3 text-sm text-bark bg-cream focus:outline-none focus:ring-2 focus:ring-terracotta-500 focus:border-transparent transition-all">
                <option value="">Select a topic...</option>
                <option value="admissions">Admissions Enquiry</option>
                <option value="fees">School Fees</option>
                <option value="volunteer">Volunteering</option>
                <option value="general">General Information</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-semibold text-bark/70 uppercase tracking-widest mb-2" for="message">Message *</label>
              <textarea id="message" name="message" rows="5" required
                        class="w-full border border-terracotta-200 rounded-xl px-4 py-3 text-sm text-bark bg-cream focus:outline-none focus:ring-2 focus:ring-terracotta-500 focus:border-transparent transition-all resize-none"
                        placeholder="Tell us how we can help you..."></textarea>
            </div>
            <button type="submit" class="btn-primary w-full text-center">Send Message</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Map Placeholder -->
<section class="pb-24 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="rounded-3xl overflow-hidden shadow-lg bg-terracotta-50 border border-terracotta-100 aspect-video flex items-center justify-center reveal">
      <div class="text-center">
        <svg class="w-14 h-14 text-terracotta-300 mx-auto mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
        </svg>
        <p class="font-display text-xl font-semibold text-bark mb-2">Samunge Village, Ngorongoro District</p>
        <p class="text-bark/50 text-sm mb-5">Arusha Region, Tanzania</p>
        <a href="https://maps.google.com/?q=Samunge+Ngorongoro+Tanzania" target="_blank" rel="noopener noreferrer" class="btn-outline-dark text-sm">
          Open in Google Maps
        </a>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
