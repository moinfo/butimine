<%- include('partials/head', { title: 'Support Us' }) %>
<body class="font-body bg-cream overflow-x-hidden">

<%- include('partials/nav') %>

<!-- Page Hero -->
<section class="page-hero">
  <div class="absolute inset-0 hero-pattern opacity-20"></div>
  <div class="absolute top-0 right-0 w-96 h-96 rounded-full bg-terracotta-400/10 blur-3xl"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
    <span class="section-label text-gold-400">Make a Difference</span>
    <h1 class="font-display text-5xl md:text-6xl font-bold text-white mt-2 mb-4">
      Support <em class="text-gold-400">Butemine</em>
    </h1>
    <p class="text-white/70 text-lg max-w-2xl mx-auto leading-relaxed">
      Your donation helps us provide quality education to children in Samunge, keep 63 fee-exempt students in school, and expand our reach across Ngorongoro District.
    </p>
  </div>
</section>

<!-- Impact Section -->
<section class="py-20 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Why Donate -->
    <div class="text-center mb-16 reveal">
      <span class="section-label">Why Your Support Matters</span>
      <h2 class="section-title">Every Contribution <em class="text-terracotta-500">Changes a Life</em></h2>
      <div class="gold-divider mx-auto mt-5"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
      <% [
        { icon: 'M12 14l9-5-9-5-9 5 9 5z', title: 'Keep Children in School', desc: '63 students currently attend Butemine entirely free of charge. Your donation ensures no child is turned away due to financial hardship.', color: 'terracotta' },
        { icon: 'M19 21V5a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v5m-4 0h4', title: 'Build Better Facilities', desc: 'Help us improve classrooms, libraries, and sanitation facilities across our three centres in Samunge, Sale, and Jema.', color: 'gold' },
        { icon: 'M17 20h5v-2a3 3 0 0 0-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 0 1 5.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 0 1 9.288 0', title: 'Support Our Teachers', desc: 'Our 15 dedicated teachers work in remote conditions. Your support helps us pay fair salaries and provide training opportunities.', color: 'forest' },
      ].forEach((item, i) => { %>
      <div class="card reveal text-center" style="transition-delay: <%= i * 80 %>ms">
        <div class="w-14 h-14 rounded-2xl bg-<%= item.color %>-50 border border-<%= item.color %>-200 mx-auto mb-5 flex items-center justify-center">
          <svg class="w-7 h-7 text-<%= item.color %>-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="<%= item.icon %>"/>
          </svg>
        </div>
        <h3 class="font-display text-lg font-bold text-bark mb-3"><%= item.title %></h3>
        <p class="text-bark/65 text-sm leading-relaxed"><%= item.desc %></p>
      </div>
      <% }) %>
    </div>

    <!-- Bank Details + Mobile Money -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">

      <!-- Bank Transfer -->
      <div class="card reveal">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-11 h-11 rounded-xl bg-terracotta-50 border border-terracotta-200 flex items-center justify-center">
            <svg class="w-5 h-5 text-terracotta-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4z"/>
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold text-bark">Bank Transfer</h3>
        </div>

        <div class="space-y-4">
          <% [
            ['Account Name',   'Butemine Primary School'],
            ['Bank Name',      'NMB Bank'],
            ['Account Number', '41110014106'],
          ].forEach(([label, value]) => { %>
          <div class="flex flex-col sm:flex-row sm:items-center gap-1 py-3 border-b border-terracotta-50 last:border-0">
            <span class="text-xs font-semibold text-bark/50 uppercase tracking-widest sm:w-40 shrink-0"><%= label %></span>
            <span class="font-medium text-bark text-sm break-all <%= value.startsWith('—') ? 'italic text-bark/40' : '' %>"><%= value %></span>
          </div>
          <% }) %>
        </div>

        <div class="mt-5 p-4 bg-terracotta-50 rounded-xl border border-terracotta-100 text-xs text-bark/60 leading-relaxed">
          <strong class="text-bark/80">Reference:</strong> Please use <strong class="text-terracotta-500">"DONATION – [Your Name]"</strong> as the payment reference so we can acknowledge your contribution.
        </div>
      </div>

      <!-- Mobile Money -->
      <div class="space-y-5">
        <div class="card reveal">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-11 h-11 rounded-xl bg-gold-50 border border-gold-200 flex items-center justify-center">
              <svg class="w-5 h-5 text-gold-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M12 18h.01M8 21h8a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2z"/>
              </svg>
            </div>
            <h3 class="font-display text-xl font-bold text-bark">Mobile Money (Tanzania)</h3>
          </div>

          <div class="space-y-3">
            <!-- Airtel Money -->
            <div class="p-4 rounded-xl border bg-terracotta-50 border-terracotta-200">
              <div class="flex items-center justify-between mb-3">
                <span class="font-bold text-sm text-terracotta-700">Airtel Money</span>
                <span class="text-xs bg-terracotta-500 text-white px-2 py-0.5 rounded-full">Active</span>
              </div>
              <div class="space-y-2">
                <div class="flex justify-between text-sm">
                  <span class="text-bark/50 text-xs uppercase tracking-widest">Phone Number</span>
                  <span class="font-mono font-semibold text-bark">0788 384 862</span>
                </div>
                <div class="flex justify-between text-sm">
                  <span class="text-bark/50 text-xs uppercase tracking-widest">Lipa Namba</span>
                  <span class="font-mono font-semibold text-bark">133013392</span>
                </div>
                <div class="flex justify-between text-sm">
                  <span class="text-bark/50 text-xs uppercase tracking-widest">Account Name</span>
                  <span class="font-semibold text-bark text-xs text-right max-w-[60%]">Butemine Primary School</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- International Donors Note -->
        <div class="card reveal border-l-4 border-l-forest-500 bg-forest-50">
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-forest-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
            <div>
              <h4 class="font-display font-bold text-bark mb-1 text-sm">International Donors</h4>
              <p class="text-bark/70 text-xs leading-relaxed">
                For international transfers please contact us directly. We will provide SWIFT/BIC details and guidance on the most cost-effective transfer method to Tanzania.
              </p>
              <a href="/contact" class="inline-flex items-center gap-1 text-forest-600 text-xs font-semibold mt-2 hover:gap-2 transition-all">
                Contact us for details
                <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Confirmation note -->
    <div class="reveal max-w-3xl mx-auto text-center">
      <div class="bg-bark text-white rounded-2xl p-8">
        <svg class="w-10 h-10 text-gold-400 mx-auto mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
        </svg>
        <h3 class="font-display text-xl font-bold mb-3">After Your Donation</h3>
        <p class="text-white/70 text-sm leading-relaxed max-w-xl mx-auto">
          Please send us a message via WhatsApp or email with your name and payment confirmation so we can acknowledge your generous contribution and send you a receipt.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center mt-6">
          <a href="https://wa.me/255788384699" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm transition-all hover:opacity-90"
             style="background:#25D366; color:white;">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
            Confirm via WhatsApp
          </a>
          <a href="/contact" class="btn-outline text-sm">Send a Message</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Sponsor a Student -->
<section class="py-24 relative overflow-hidden" style="background: linear-gradient(160deg, #0D1B3E 0%, #1A3478 60%, #4A90D9 100%);">
  <div class="absolute inset-0 hero-pattern opacity-10"></div>
  <div class="absolute top-0 right-0 w-96 h-96 bg-gold-500/10 blur-3xl rounded-full"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <span class="section-label text-gold-400">Sponsor a Student</span>
      <h2 class="section-title-light">Give a Child a <em class="text-gold-400">Future</em></h2>
      <div class="gold-divider mx-auto mt-5"></div>
      <p class="text-white/70 max-w-2xl mx-auto mt-5 leading-relaxed">
        Butemine is home to many orphans and children from families too poor to afford school fees.
        Your sponsorship pays directly for a child's education — their fees, books, and uniform —
        and keeps them in school throughout the year.
      </p>
    </div>

    <!-- Student need stats -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-16">
      <% [
        { num: '63', label: 'Students currently fee-exempt', desc: 'Children attending Butemine fully supported by the school\'s goodwill — they need a dedicated sponsor.' },
        { num: '209', label: 'Total students enrolled', desc: 'Many more students come from families who struggle monthly to keep their children in school.' },
        { num: '3', label: 'Centres across Ngorongoro', desc: 'Remote locations mean families have very limited income options and little access to financial support.' },
      ].forEach(s => { %>
      <div class="bg-white/8 border border-white/15 rounded-2xl p-7 text-center reveal hover:bg-white/12 transition-colors duration-300">
        <div class="font-display text-5xl font-bold text-gold-400 mb-2"><%= s.num %></div>
        <div class="text-white font-semibold text-sm mb-3 uppercase tracking-widest"><%= s.label %></div>
        <p class="text-white/55 text-xs leading-relaxed"><%= s.desc %></p>
      </div>
      <% }) %>
    </div>

    <!-- Sponsorship tiers -->
    <div class="text-center mb-10 reveal">
      <h3 class="font-display text-2xl text-white font-bold">Choose Your Sponsorship Level</h3>
      <p class="text-white/60 text-sm mt-2">All amounts are per student, per year.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-14">
      <% [
        {
          tier: 'Basic',
          amount: 'TZS 150,000',
          usd: '~$55 / year',
          color: 'gold',
          covers: ['School fees (one term)', 'Exercise books & pens', 'Basic learning materials'],
          icon: '📚',
        },
        {
          tier: 'Full Year',
          amount: 'TZS 450,000',
          usd: '~$165 / year',
          color: 'terracotta',
          covers: ['Full annual school fees', 'All books & stationery', 'School uniform', 'Exam registration fees'],
          icon: '🎓',
          featured: true,
        },
        {
          tier: 'Champion',
          amount: 'TZS 900,000',
          usd: '~$330 / year',
          color: 'forest',
          covers: ['Full annual fees for 2 students', 'All materials & uniforms', 'School meals contribution', 'Progress updates with photos'],
          icon: '⭐',
        },
      ].forEach(t => { %>
      <div class="reveal relative <%= t.featured ? 'scale-105' : '' %>">
        <% if (t.featured) { %>
        <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-gold-500 text-white text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-widest whitespace-nowrap">Most Impactful</div>
        <% } %>
        <div class="bg-white rounded-2xl p-7 h-full flex flex-col shadow-xl <%= t.featured ? 'border-2 border-gold-400' : 'border border-white/20' %>">
          <div class="text-3xl mb-3"><%= t.icon %></div>
          <div class="text-xs font-bold text-<%= t.color %>-500 uppercase tracking-widest mb-1"><%= t.tier %></div>
          <div class="font-display text-2xl font-bold text-bark mb-1"><%= t.amount %></div>
          <div class="text-bark/50 text-xs mb-6"><%= t.usd %></div>
          <ul class="space-y-2.5 mb-8 flex-1">
            <% t.covers.forEach(item => { %>
            <li class="flex items-start gap-2.5 text-sm text-bark/75">
              <svg class="w-4 h-4 text-<%= t.color %>-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
              <%= item %>
            </li>
            <% }) %>
          </ul>
          <a href="https://wa.me/255788384699?text=Hello%2C%20I%20would%20like%20to%20sponsor%20a%20student%20at%20Butemine%20School%20(<%= encodeURIComponent(t.tier) %>%20level)" target="_blank" rel="noopener noreferrer"
             class="block text-center py-3 rounded-xl font-semibold text-sm transition-all duration-300 <%= t.featured ? 'bg-gold-500 text-white hover:bg-gold-600' : 'border-2 border-' + t.color + '-500 text-' + t.color + '-600 hover:bg-' + t.color + '-500 hover:text-white' %>">
            Sponsor at this Level
          </a>
        </div>
      </div>
      <% }) %>
    </div>

    <!-- How it works -->
    <div class="bg-white/8 border border-white/15 rounded-3xl p-10 reveal">
      <h3 class="font-display text-xl text-white font-bold mb-8 text-center">How Sponsorship Works</h3>
      <div class="grid grid-cols-1 sm:grid-cols-4 gap-6 text-center">
        <% [
          ['01', 'Choose a Level', 'Pick the sponsorship tier that works for you — any amount makes a difference.'],
          ['02', 'Contact Us', 'Reach us via WhatsApp or email. We will match you with a student and share their story.'],
          ['03', 'Transfer Funds', 'Send your contribution via NMB Bank or Airtel Money to the school account.'],
          ['04', 'Receive Updates', 'We send you regular updates and photos of the student you\'re supporting.'],
        ].forEach(([num, title, desc]) => { %>
        <div>
          <div class="w-10 h-10 rounded-full bg-gold-500 text-white font-bold text-sm flex items-center justify-center mx-auto mb-3"><%= num %></div>
          <h4 class="font-display font-bold text-white text-sm mb-2"><%= title %></h4>
          <p class="text-white/55 text-xs leading-relaxed"><%= desc %></p>
        </div>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<!-- Thank You Banner -->
<section class="py-16 relative overflow-hidden" style="background: linear-gradient(135deg, #0D1B3E 0%, #1A3478 100%);">
  <div class="absolute inset-0 hero-pattern opacity-10"></div>
  <div class="relative z-10 max-w-3xl mx-auto px-4 text-center reveal">
    <h2 class="font-display text-3xl md:text-4xl text-white font-bold mb-4">
      Thank You for Your <em class="text-gold-400">Generosity</em>
    </h2>
    <p class="text-white/70 leading-relaxed">
      Every shilling and every dollar goes directly to the children of Butemine School. On behalf of our 209 students, 15 teachers, and the entire Samunge community — <strong class="text-white">asante sana.</strong>
    </p>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
