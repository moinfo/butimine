<%- include('partials/head', { title: 'Gallery' }) %>
<body class="font-body bg-cream overflow-x-hidden">

<%- include('partials/nav') %>

<!-- Page Hero -->
<section class="page-hero">
  <div class="absolute inset-0 hero-pattern opacity-20"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
    <span class="section-label text-gold-400"><%= t.gallery_hero_label %></span>
    <h1 class="font-display text-5xl md:text-6xl font-bold text-white mt-2 mb-4"><%= t.gallery_hero_title %> <em class="text-gold-400">Butemine</em></h1>
    <p class="text-white/70 text-lg max-w-2xl mx-auto"><%= t.gallery_hero_sub %></p>
  </div>
</section>

<!-- Gallery Grid -->
<section class="py-24 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Filter bar -->
    <div class="flex flex-wrap gap-3 justify-center mb-12 reveal">
      <%
        const filters = [
          { key: 'all',        label: t.gallery_filter_all },
          { key: 'graduation', label: t.gallery_filter_graduation },
          { key: 'sports',     label: t.gallery_filter_sports },
          { key: 'talent',     label: t.gallery_filter_talent },
          { key: 'outreach',   label: t.gallery_filter_outreach },
          { key: 'campus',     label: t.gallery_filter_campus },
          { key: 'awards',     label: t.gallery_filter_awards },
        ];
      %>
      <% filters.forEach((f, i) => { %>
      <button
        data-filter="<%= f.key %>"
        class="gallery-filter-btn px-5 py-2 rounded-full text-sm font-semibold transition-all duration-200 <%= i === 0 ? 'bg-terracotta-500 text-white' : 'bg-white border border-terracotta-200 text-bark/70 hover:border-terracotta-500 hover:text-terracotta-500' %>">
        <%= f.label %>
      </button>
      <% }) %>
    </div>

    <!-- Masonry-style grid -->
    <%
      const photos = [
        { file: 1,  cat: 'graduation' },
        { file: 2,  cat: 'graduation' },
        { file: 3,  cat: 'graduation' },
        { file: 4,  cat: 'graduation' },
        { file: 5,  cat: 'sports'     },
        { file: 6,  cat: 'sports'     },
        { file: 7,  cat: 'sports'     },
        { file: 8,  cat: 'talent'     },
        { file: 9,  cat: 'talent'     },
        { file: 10, cat: 'talent'     },
        { file: 11, cat: 'outreach'   },
        { file: 12, cat: 'outreach'   },
        { file: 13, cat: 'outreach'   },
        { file: 14, cat: 'campus'     },
        { file: 15, cat: 'campus'     },
        { file: 16, cat: 'campus'     },
        { file: 17, cat: 'campus'     },
        { src: '/images/awards1.jpeg',  cat: 'awards' },
        { src: '/images/awards2.jpeg',  cat: 'awards' },
        { src: '/images/awards3.jpeg',  cat: 'awards' },
        { src: '/images/awards4.jpeg',  cat: 'awards' },
        { src: '/images/awards5.jpeg',  cat: 'awards' },
        { src: '/images/awards6.jpeg',  cat: 'awards' },
        { src: '/images/awards7.jpeg',  cat: 'awards' },
        { src: '/images/awards8.jpeg',  cat: 'awards' },
        { src: '/images/awards9.jpeg',  cat: 'awards' },
        { src: '/images/awards10.jpeg', cat: 'awards' },
        { src: '/images/awards11.jpeg', cat: 'awards' },
        { src: '/images/awards12.jpeg', cat: 'awards' },
        { src: '/images/awards13.jpeg', cat: 'awards' },
        { src: '/images/new.jpeg',      cat: 'outreach' },
        { src: '/images/new2.jpeg',     cat: 'outreach' },
        { src: '/images/new3.jpeg',     cat: 'outreach' },
        { src: '/images/mpya1.jpeg',    cat: 'campus'     },
        { src: '/images/mpya2.jpeg',    cat: 'graduation' },
        { src: '/images/mpya3.jpeg',    cat: 'graduation' },
        { src: '/images/mpya4.jpeg',    cat: 'graduation' },
        { src: '/images/mpya5.jpeg',    cat: 'graduation' },
        { src: '/images/mpya6.jpeg',    cat: 'campus'     },
        { src: '/images/mpya7.jpeg',    cat: 'campus'     },
        { src: '/images/mpya8.jpeg',    cat: 'campus'     },
        { src: '/images/mpya9.jpeg',    cat: 'campus'     },
      ];
    %>
    <div class="columns-1 sm:columns-2 lg:columns-3 gap-5 space-y-5" id="gallery-grid">
      <% photos.forEach(p => { %>
      <div class="gallery-item break-inside-avoid rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 bg-terracotta-100 reveal group cursor-pointer relative"
           data-category="<%= p.cat %>">
        <img src="<%= p.src || '/images/File ' + p.file + '.jpg' %>"
             alt="Butemine School photo"
             class="w-full h-auto block group-hover:scale-105 transition-transform duration-500" />
        <div class="absolute inset-0 bg-bark/0 group-hover:bg-bark/30 transition-all duration-400 flex items-end justify-start p-4">
          <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-terracotta-500 text-white text-xs font-bold px-3 py-1 rounded-full capitalize"><%= p.cat %></span>
        </div>
      </div>
      <% }) %>
    </div>

    <!-- Empty state (shown when no results) -->
    <div id="gallery-empty" class="hidden text-center py-16">
      <p class="text-bark/40 font-display text-xl">No photos in this category yet.</p>
    </div>

    <!-- Note about more photos -->
    <div class="text-center mt-16 reveal">
      <div class="bg-gold-50 border border-gold-200 rounded-2xl p-8 inline-block max-w-lg">
        <svg class="w-8 h-8 text-gold-500 mx-auto mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/>
        </svg>
        <h4 class="font-display font-bold text-bark text-lg mb-2"><%= t.gallery_note_title %></h4>
        <p class="text-bark/60 text-sm"><%= t.gallery_note_body %></p>
        <div class="flex gap-3 justify-center mt-5">
          <a href="https://www.facebook.com/share/1CfGeEVe3b/" target="_blank" rel="noopener noreferrer"
             class="flex items-center gap-2 bg-white border border-gold-200 text-bark/70 hover:text-gold-600 hover:border-gold-400 px-4 py-2 rounded-lg text-sm font-medium transition-all">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            Facebook
          </a>
          <a href="https://www.instagram.com/butemineschool" target="_blank" rel="noopener noreferrer"
             class="flex items-center gap-2 bg-white border border-gold-200 text-bark/70 hover:text-gold-600 hover:border-gold-400 px-4 py-2 rounded-lg text-sm font-medium transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            Instagram
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const btns  = document.querySelectorAll('.gallery-filter-btn');
  const items = document.querySelectorAll('#gallery-grid .gallery-item');
  const empty = document.getElementById('gallery-empty');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;

      // Update active button style
      btns.forEach(b => {
        b.classList.remove('bg-terracotta-500', 'text-white');
        b.classList.add('bg-white', 'border', 'border-terracotta-200', 'text-bark/70');
      });
      btn.classList.add('bg-terracotta-500', 'text-white');
      btn.classList.remove('bg-white', 'border', 'border-terracotta-200', 'text-bark/70');

      // Show/hide items
      let visible = 0;
      items.forEach(item => {
        const match = filter === 'all' || item.dataset.category === filter;
        item.style.display = match ? '' : 'none';
        if (match) visible++;
      });

      empty.classList.toggle('hidden', visible > 0);
    });
  });
</script>

<%- include('partials/footer') %>
</body>
</html>
