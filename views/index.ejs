<%- include('partials/head', { title: 'Home' }) %>
<body class="font-body bg-cream overflow-x-hidden">

<%- include('partials/nav') %>

<!-- ═══════════════════════════════════════════
     HERO
════════════════════════════════════════════ -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden"
         style="background: linear-gradient(150deg, #070E1F 0%, #0D1B3E 30%, #1A3478 65%, #4A90D9 100%);">

  <!-- Dot texture -->
  <div class="absolute inset-0 hero-pattern opacity-30"></div>

  <!-- Floating decorative orbs -->
  <div class="float-1 absolute top-1/4 left-[8%] w-32 h-32 rounded-full border border-gold-500/20 bg-gold-500/5"></div>
  <div class="float-2 absolute top-1/3 right-[10%] w-48 h-48 rounded-full border border-terracotta-400/20 bg-terracotta-500/5"></div>
  <div class="float-3 absolute bottom-1/4 left-[20%] w-20 h-20 rounded-full bg-white/5 border border-white/10"></div>
  <div class="float-1 absolute bottom-1/3 right-[15%] w-14 h-14 rounded-full border-2 border-gold-400/30"></div>

  <!-- Glow blobs -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full bg-gold-500/8 blur-[120px] -translate-y-1/3 translate-x-1/3"></div>
  <div class="absolute bottom-0 left-0 w-[500px] h-[500px] rounded-full bg-terracotta-500/15 blur-[100px] translate-y-1/3 -translate-x-1/4"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-4 text-center text-white pt-20">
    <div class="animate-fade-in mb-8 inline-block relative">
      <img src="/logo.png" alt="Butemine School"
           class="h-28 w-28 mx-auto object-contain bg-white/10 rounded-full p-2 border border-white/20 shadow-2xl" />
    </div>

    <p class="animate-fade-in-up delay-100 text-gold-400 font-semibold text-sm tracking-[0.25em] uppercase mb-4">
      Samunge · Tanzania · Est. 2013
    </p>

    <h1 class="animate-fade-in-up delay-200 font-display text-5xl sm:text-6xl md:text-7xl font-bold leading-[1.1] mb-6">
      Butemine<br />
      <em class="text-gold-400 not-italic">Primary</em><br />
      <span class="text-white/90">School</span>
    </h1>

    <p class="animate-fade-in-up delay-300 text-white/75 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
      <%= t.home_hero_subtitle %>
    </p>

    <div class="animate-fade-in-up delay-400 flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/about" class="btn-primary text-base px-10 py-4"><%= t.home_hero_btn_discover %></a>
      <a href="/admissions" class="btn-outline text-base px-10 py-4"><%= t.home_hero_btn_apply %></a>
      <a href="/donate" class="inline-flex items-center gap-2 text-gold-400 hover:text-gold-300 font-semibold text-sm transition-colors py-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4.318 6.318a4.5 4.5 0 0 0 0 6.364L12 20.364l7.682-7.682a4.5 4.5 0 0 0-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 0 0-6.364 0z"/></svg>
        <%= t.home_hero_support %>
      </a>
    </div>

    <!-- Quick contact bar -->
    <div class="animate-fade-in-up delay-400 mt-12 inline-flex flex-wrap justify-center gap-5 text-white/50 text-sm">
      <a href="tel:+255788384699" class="flex items-center gap-2 hover:text-gold-400 transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.21 3.18 2 2 0 0 1 3.22 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16z"/></svg>
        +255 788 384 699
      </a>
      <span>·</span>
      <a href="https://www.facebook.com/share/1CfGeEVe3b/" target="_blank" rel="noopener noreferrer" class="hover:text-gold-400 transition-colors">Facebook</a>
      <span>·</span>
      <a href="https://www.instagram.com/butemineschool" target="_blank" rel="noopener noreferrer" class="hover:text-gold-400 transition-colors">Instagram</a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce">
    <span class="text-white/30 text-[10px] uppercase tracking-[0.2em]">Scroll</span>
    <svg class="w-5 h-5 text-gold-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M12 5v14M19 12l-7 7-7-7"/>
    </svg>
  </div>

  <!-- Bottom wave -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" class="w-full block" style="height:80px">
      <path d="M0,40 C360,80 720,0 1080,40 C1260,60 1380,30 1440,40 L1440,80 L0,80 Z" class="fill-bark dark:fill-[#080F20]"/>
    </svg>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     STATS
════════════════════════════════════════════ -->
<section class="bg-bark pt-2 pb-14">
  <div class="max-w-5xl mx-auto px-4">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      <% [
        { target: 209, suffix: '', label: t.home_stats_students, icon: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2' },
        { target: 3,   suffix: '', label: t.home_stats_centres,    icon: 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z' },
        { target: 2013, suffix: '', label: t.home_stats_founded,     icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2z' },
        { target: 15,  suffix: '+', label: t.home_stats_staff,   icon: 'M12 4.354a4 4 0 1 1 0 5.292M15 21H3v-1a6 6 0 0 1 12 0v1zm0 0h6v-1a6 6 0 0 0-9-5.197' },
      ].forEach(s => { %>
      <div class="reveal text-center group">
        <div class="w-12 h-12 mx-auto mb-3 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center group-hover:bg-gold-500/20 transition-colors duration-300">
          <svg class="w-5 h-5 text-gold-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="<%= s.icon %>"/>
          </svg>
        </div>
        <div class="font-display text-4xl font-bold text-gold-400 mb-1"
             data-target="<%= s.target %>" data-suffix="<%= s.suffix %>">
          <%= s.target %><%= s.suffix %>
        </div>
        <div class="text-white/70 text-xs uppercase tracking-widest"><%= s.label %></div>
      </div>
      <% }) %>
    </div>
  </div>

  <!-- Wave to cream -->
  <div class="mt-14 -mb-1">
    <svg viewBox="0 0 1440 70" preserveAspectRatio="none" class="w-full block" style="height:70px">
      <path d="M0,0 C180,70 360,0 540,35 C720,70 900,0 1080,35 C1260,70 1380,20 1440,35 L1440,70 L0,70 Z" class="fill-cream dark:fill-[#080F20]"/>
    </svg>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     SERVICES
════════════════════════════════════════════ -->
<section class="py-16 md:py-24 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 md:mb-16 reveal">
      <span class="section-label"><%= t.home_offer_label %></span>
      <h2 class="section-title"><%= t.home_offer_title %><br /><em class="text-terracotta-500"><%= t.home_offer_title2 %></em></h2>
      <div class="gold-divider mx-auto mt-5"></div>
      <p class="text-bark/75 max-w-xl mx-auto mt-4 text-sm leading-relaxed"><%= t.home_offer_sub %></p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <% [
        {
          num: '01',
          color: 'terracotta',
          badge: 'Ages 0 – 3',
          title: t.home_service_daycare,
          location: t.home_service_daycare_loc,
          desc: t.home_service_daycare_desc,
          link: '/schools',
        },
        {
          num: '02',
          color: 'gold',
          badge: 'Ages 3 – 6',
          title: t.home_service_nursery,
          location: t.home_service_nursery_loc,
          desc: t.home_service_nursery_desc,
          link: '/schools',
        },
        {
          num: '03',
          color: 'forest',
          badge: 'Standard 1 – 7',
          title: t.home_service_primary,
          location: t.home_service_primary_loc,
          desc: t.home_service_primary_desc,
          link: '/schools',
        },
      ].forEach((s, i) => { %>
      <div class="card group reveal" style="transition-delay: <%= i * 80 %>ms">
        <div class="flex items-start justify-between mb-6">
          <div class="w-14 h-14 rounded-2xl bg-<%= s.color %>-50 border border-<%= s.color %>-200 flex items-center justify-center group-hover:bg-<%= s.color %>-100 transition-colors duration-300">
            <span class="font-display font-bold text-<%= s.color %>-500 text-lg"><%= s.num %></span>
          </div>
          <span class="text-xs font-bold bg-<%= s.color %>-100 text-<%= s.color %>-700 px-3 py-1.5 rounded-full"><%= s.badge %></span>
        </div>
        <h3 class="font-display text-xl font-bold text-bark mb-1"><%= s.title %></h3>
        <p class="text-gold-600 text-xs font-semibold uppercase tracking-wider mb-4 flex items-center gap-1">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <%= s.location %>
        </p>
        <p class="text-bark/80 text-sm leading-relaxed mb-6"><%= s.desc %></p>
        <a href="<%= s.link %>" class="inline-flex items-center gap-1.5 text-terracotta-500 text-sm font-semibold group-hover:gap-3 transition-all duration-300">
          <%= t.home_service_learn %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     ABOUT PREVIEW
════════════════════════════════════════════ -->
<section class="py-16 md:py-24 relative overflow-hidden" style="background: linear-gradient(160deg, #0D1B3E 0%, #070E1F 100%);">
  <div class="absolute inset-0 hero-pattern opacity-10"></div>
  <div class="absolute top-0 right-0 w-96 h-96 bg-gold-500/8 blur-3xl rounded-full -translate-y-1/4 translate-x-1/4"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">

      <!-- Image -->
      <div class="reveal relative order-2 lg:order-1">
        <div class="relative">
          <!-- Decorative frame -->
          <div class="absolute -top-4 -left-4 right-8 bottom-8 border border-gold-500/30 rounded-3xl"></div>
          <div class="rounded-3xl overflow-hidden shadow-2xl aspect-[4/3] bg-terracotta-900">
            <img src="/images/File 1.jpg" alt="Butemine School" class="w-full h-full object-cover opacity-90 hover:opacity-100 transition-opacity duration-500" />
          </div>
          <!-- Floating info card -->
          <div class="absolute -bottom-4 right-0 sm:-bottom-6 sm:-right-4 bg-gold-500 text-bark rounded-2xl p-4 sm:p-5 shadow-2xl">
            <div class="font-display text-3xl font-bold leading-none">209</div>
            <div class="text-xs font-semibold uppercase tracking-wider mt-1 text-bark/80"><%= t.home_story_students %></div>
          </div>
        </div>
      </div>

      <!-- Text -->
      <div class="reveal order-1 lg:order-2">
        <span class="section-label text-gold-400"><%= t.home_story_label %></span>
        <h2 class="text-4xl md:text-5xl font-display font-bold text-white mb-5">
          <%= t.home_story_title %><br /><em class="text-gold-400"><%= t.home_story_title2 %></em>
        </h2>
        <div class="gold-divider mb-6"></div>
        <p class="text-white/70 leading-relaxed mb-5"><%- t.home_story_body1 %></p>
        <p class="text-white/70 leading-relaxed mb-8"><%- t.home_story_body2 %></p>
        <blockquote class="border-l-4 border-gold-500 pl-5 mb-8 py-2">
          <p class="font-display text-lg italic text-white/90"><%= t.home_story_quote %></p>
        </blockquote>
        <a href="/about" class="btn-gold"><%= t.btn_read_story %></a>
      </div>
    </div>
  </div>

  <!-- Bottom wave -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 70" preserveAspectRatio="none" class="w-full block" style="height:70px">
      <path d="M0,35 C360,0 720,70 1080,35 C1260,18 1380,50 1440,35 L1440,70 L0,70 Z" class="fill-cream dark:fill-[#080F20]"/>
    </svg>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     GALLERY PREVIEW
════════════════════════════════════════════ -->
<section class="pt-16 md:pt-24 pb-12 md:pb-16 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-8 md:mb-12 gap-4 md:gap-6">
      <div class="reveal">
        <span class="section-label"><%= t.home_gallery_label %></span>
        <h2 class="section-title"><%= t.home_gallery_title %> <em class="text-terracotta-500">Butemine</em></h2>
        <div class="gold-divider mt-5"></div>
      </div>
      <a href="/gallery" class="btn-outline-dark self-start reveal"><%= t.home_gallery_btn %></a>
    </div>

    <!-- Featured gallery grid: 2-col on mobile, 3-col with span on sm+ -->
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 md:gap-4">
      <!-- Large image: full-width on mobile, tall-left on sm+ -->
      <div class="gallery-item col-span-2 sm:col-span-1 sm:row-span-2 rounded-2xl overflow-hidden bg-terracotta-100 shadow-sm hover:shadow-xl transition-shadow duration-400 reveal relative aspect-video sm:aspect-auto" style="min-height:0">
        <img src="/images/File 1.jpg" alt="Butemine School" class="w-full h-full object-cover absolute inset-0" />
        <div class="overlay absolute inset-0 bg-bark/30 flex items-end p-4 sm:p-5">
          <span class="text-white text-sm font-semibold">School Life</span>
        </div>
      </div>
      <!-- 4 square thumbnails -->
      <% for (let i = 2; i <= 5; i++) { %>
      <div class="gallery-item col-span-1 rounded-2xl overflow-hidden bg-terracotta-100 shadow-sm hover:shadow-xl transition-shadow duration-400 reveal relative aspect-square">
        <img src="/images/File <%= i %>.jpg" alt="Butemine photo" class="w-full h-full object-cover absolute inset-0" />
        <div class="overlay absolute inset-0 bg-bark/20 flex items-end p-2 sm:p-3">
          <span class="text-white text-xs font-medium">Photo <%= i %></span>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     TESTIMONIALS
════════════════════════════════════════════ -->
<section class="py-14 md:py-20 bg-cream border-y border-terracotta-100">
  <div class="max-w-5xl mx-auto px-4">
    <div class="text-center mb-10 md:mb-12 reveal">
      <span class="section-label"><%= t.home_testimonials_label %></span>
      <h2 class="section-title"><%= t.home_testimonials_h %> <em class="text-terracotta-500"><%= t.home_testimonials_h_em %></em></h2>
    </div>

    <div class="relative min-h-[300px] sm:min-h-[224px] reveal" id="testimonial-wrap">
      <% [
        { quote: t.home_testimonial1_quote, name: t.home_testimonial1_name, place: t.home_testimonial1_place },
        { quote: t.home_testimonial2_quote, name: t.home_testimonial2_name, place: t.home_testimonial2_place },
        { quote: t.home_testimonial3_quote, name: t.home_testimonial3_name, place: t.home_testimonial3_place },
      ].forEach((testimonial, i) => { %>
      <div class="testimonial-card <%= i === 0 ? 't-active' : '' %>">
        <svg class="w-8 h-8 text-gold-500 mb-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
          <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
        </svg>
        <p class="font-display text-lg md:text-2xl italic text-bark/90 leading-relaxed mb-5"><%= testimonial.quote %></p>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-terracotta-100 border-2 border-terracotta-200 flex items-center justify-center">
            <svg class="w-5 h-5 text-terracotta-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.58-7 8-7s8 3 8 7"/></svg>
          </div>
          <div>
            <div class="text-sm font-semibold text-bark"><%= testimonial.name %></div>
            <div class="text-xs text-gold-600"><%= testimonial.place %></div>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     LOCATION / TOURIST
════════════════════════════════════════════ -->
<section class="py-16 md:py-24 relative overflow-hidden"
         style="background: linear-gradient(135deg, #1A7A3A 0%, #0C3B1C 100%);">
  <div class="absolute inset-0 hero-pattern opacity-15"></div>
  <div class="absolute right-0 top-0 w-96 h-96 bg-gold-500/10 blur-3xl rounded-full"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <div class="reveal">
        <span class="section-label text-gold-400"><%= t.home_location_label %></span>
        <h2 class="text-4xl md:text-5xl font-display font-bold text-white mb-5">
          <%= t.home_location_title %><br /><em class="text-gold-400"><%= t.home_location_title2 %></em>
        </h2>
        <div class="gold-divider mb-6"></div>
        <p class="text-white/70 leading-relaxed mb-4"><%= t.home_location_desc %></p>
        <p class="text-white/60 text-sm leading-relaxed mb-8"><%= t.home_location_address %></p>
        <a href="/contact" class="btn-gold"><%= t.home_location_btn %></a>
      </div>

      <div class="reveal">
        <h4 class="font-display text-lg text-gold-400 mb-5 font-semibold"><%= t.home_location_nearby %></h4>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <% ['Serengeti National Park', 'Ngorongoro Conservation Area', 'Mount Oldonyo Lengai', 'Lake Natron', 'Shimo la Mungu', 'Clency-Ololosokwan'].forEach((site, i) => { %>
          <div class="reveal group flex items-center gap-3 bg-white/8 hover:bg-white/15 border border-white/10 hover:border-gold-500/40 rounded-xl px-4 py-3 transition-all duration-300 cursor-default" style="transition-delay: <%= i*50 %>ms">
            <span class="w-2 h-2 bg-gold-400 rounded-full shrink-0 group-hover:scale-125 transition-transform"></span>
            <span class="text-white/85 text-sm font-medium"><%= site %></span>
          </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 70" preserveAspectRatio="none" class="w-full block" style="height:70px">
      <path d="M0,0 C480,70 960,0 1440,35 L1440,70 L0,70 Z" fill="#4A90D9"/>
    </svg>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     VOLUNTEERS / COMMUNITY
════════════════════════════════════════════ -->
<section class="py-16 md:py-24 bg-terracotta-500 relative overflow-hidden">
  <div class="absolute inset-0 hero-pattern opacity-10"></div>
  <div class="absolute -top-32 -left-32 w-80 h-80 bg-white/5 rounded-full"></div>
  <div class="absolute -bottom-20 -right-20 w-64 h-64 bg-white/5 rounded-full"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <div class="reveal">
        <span class="section-label text-gold-300"><%= t.home_impact_label %></span>
        <h2 class="section-title-light mb-5">
          <%= t.home_community_title %><br /><em class="text-gold-300"><%= t.home_community_title2 %></em>
        </h2>
        <div class="gold-divider mb-6"></div>
        <p class="text-white/80 leading-relaxed mb-6"><%= t.home_community_body %></p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="btn-outline"><%= t.home_community_volunteer_btn %></a>
          <a href="/about" class="inline-flex items-center gap-2 text-white/85 hover:text-white font-semibold transition-colors py-3">
            <%= t.home_community_work_link %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-5 reveal">
        <% [
          ['63', t.home_community_stat1],
          ['3', t.home_community_stat2],
          ['∞', t.home_community_stat3],
          ['2013', t.home_community_stat4],
        ].forEach(([n, l]) => { %>
        <div class="bg-white/10 border border-white/20 hover:bg-white/15 transition-colors duration-300 rounded-2xl p-5 text-center">
          <div class="font-display text-3xl font-bold text-gold-300 mb-1"><%= n %></div>
          <div class="text-white/80 text-xs leading-snug"><%= l %></div>
        </div>
        <% }) %>
