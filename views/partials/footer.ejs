<!-- WhatsApp Floating Button -->
<a href="https://wa.me/255788384699" target="_blank" rel="noopener noreferrer"
   aria-label="Chat on WhatsApp"
   class="whatsapp-btn fixed bottom-6 right-6 z-50 w-14 h-14 rounded-full flex items-center justify-center shadow-xl hover:scale-110 transition-transform duration-300"
   style="background:#25D366;">
  <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
  </svg>
</a>

<!-- Back to top -->
<button id="back-to-top" aria-label="Back to top"
        class="fixed bottom-6 left-6 z-50 w-11 h-11 rounded-full bg-terracotta-500 text-white flex items-center justify-center shadow-lg opacity-0 pointer-events-none hover:bg-terracotta-600 transition-all duration-300">
  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
    <path d="M12 19V5M5 12l7-7 7 7"/>
  </svg>
</button>

<footer class="bg-bark text-white">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-5">
          <img src="/logo.png" alt="Butemine School" class="h-12 w-12 object-contain bg-white/10 rounded-full p-1" />
          <div>
            <div class="font-display font-bold text-lg leading-tight">Butemine School</div>
            <div class="text-[10px] text-gold-400 tracking-widest uppercase">Tanzania · Est. 2013</div>
          </div>
        </div>
        <p class="text-white/70 text-sm leading-relaxed mb-6">
          Providing quality education to youth in the heart of Tanzania's Ngorongoro-Serengeti ecosystem. Raising agents of change since 2013.
        </p>
        <!-- Social Media -->
        <div class="flex gap-3">
          <a href="https://www.facebook.com/share/1CfGeEVe3b/" target="_blank" rel="noopener noreferrer"
             aria-label="Facebook"
             class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-gold-500 transition-colors duration-300">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/butemineschool" target="_blank" rel="noopener noreferrer"
             aria-label="Instagram"
             class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-gold-500 transition-colors duration-300">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-display font-semibold text-lg mb-5 text-gold-400">Quick Links</h4>
        <ul class="space-y-2.5">
          <% [['/', 'Home'], ['/about', 'About Us'], ['/admissions', 'Admissions'],
              ['/schools', 'Our Schools'], ['/gallery', 'Gallery'], ['/contact', 'Contact']].forEach(([href, label]) => { %>
          <li>
            <a href="<%= href %>" class="text-white/70 hover:text-gold-400 transition-colors text-sm flex items-center gap-2">
              <span class="w-1 h-1 bg-gold-500 rounded-full"></span><%= label %>
            </a>
          </li>
          <% }) %>
        </ul>
      </div>

      <!-- Programs -->
      <div>
        <h4 class="font-display font-semibold text-lg mb-5 text-gold-400">Our Programs</h4>
        <ul class="space-y-2.5">
          <% [['Daycare Centre', 'Ages 0 – 3'], ['Nursery / Pre-school', 'Ages 3 – 6'], ['Primary School', 'Standard 1 – 7']].forEach(([prog, age]) => { %>
          <li class="text-sm">
            <div class="text-white/90 font-medium"><%= prog %></div>
            <div class="text-white/50 text-xs"><%= age %></div>
          </li>
          <% }) %>
        </ul>
        <div class="mt-5 p-3 bg-white/5 rounded-lg border border-white/10">
          <div class="text-xs text-gold-400 uppercase tracking-widest mb-1">Domain</div>
          <a href="http://www.butemine.ac.tz" class="text-white/80 text-sm hover:text-gold-400 transition-colors">www.butemine.ac.tz</a>
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-display font-semibold text-lg mb-5 text-gold-400">Get in Touch</h4>
        <ul class="space-y-4">
          <li class="flex gap-3 text-sm">
            <svg class="w-4 h-4 text-gold-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.21 3.18 2 2 0 0 1 3.22 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16z"/></svg>
            <div class="text-white/70">
              <a href="tel:+255788384699" class="hover:text-gold-400 transition-colors block">+255 788 384 699</a>
              <a href="tel:+255788384862" class="hover:text-gold-400 transition-colors block">+255 788 384 862</a>
            </div>
          </li>
          <li class="flex gap-3 text-sm">
            <svg class="w-4 h-4 text-gold-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <div class="text-white/70 leading-relaxed">
              Samunge Village, Sale Division<br/>Ngorongoro District, Arusha<br/>Tanzania
            </div>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/40">
      <p>&copy; <%= new Date().getFullYear() %> Butemine Primary School. All rights reserved.</p>
      <p>Built with care by <span class="text-gold-500">Moinfotech</span></p>
    </div>
  </div>
</footer>

<script src="/js/main.js"></script>
