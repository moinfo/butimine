<%
  var _title     = typeof title       !== 'undefined' ? title       : null;
  var _desc      = typeof description !== 'undefined' ? description : 'Butemine English Medium Pre & Primary School — quality Daycare, Nursery, and Primary education (Std 1–7) in Samunge, Ngorongoro District, Tanzania.';
  var _canonical = typeof canonical   !== 'undefined' ? canonical   : 'https://butemine.ac.tz';
  var _ogImage   = typeof ogImage     !== 'undefined' ? ogImage     : 'https://butemine.ac.tz/logo.png';
  var _fullTitle = _title ? _title + ' | Butemine School — Tanzania' : 'Butemine School — Quality Education in Tanzania';
%><!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary SEO -->
  <title><%= _fullTitle %></title>
  <meta name="description" content="<%= _desc %>" />
  <link rel="canonical" href="<%= _canonical %>" />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:site_name"   content="Butemine School" />
  <meta property="og:title"       content="<%= _fullTitle %>" />
  <meta property="og:description" content="<%= _desc %>" />
  <meta property="og:url"         content="<%= _canonical %>" />
  <meta property="og:image"       content="<%= _ogImage %>" />
  <meta property="og:locale"      content="en_TZ" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content="<%= _fullTitle %>" />
  <meta name="twitter:description" content="<%= _desc %>" />
  <meta name="twitter:image"       content="<%= _ogImage %>" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <!-- Tailwind compiled CSS -->
  <link rel="stylesheet" href="/css/style.css" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/logo.png" />

  <!-- Prevent flash of wrong theme -->
  <script>
    (function(){
      var t = localStorage.getItem('theme');
      if(t==='dark'||(t===null&&window.matchMedia('(prefers-color-scheme:dark)').matches))
        document.documentElement.classList.add('dark');
    })();
  </script>

  <!-- JSON-LD: School -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "School",
    "name": "Butemine English Medium Pre & Primary School",
    "url": "https://butemine.ac.tz",
    "logo": "https://butemine.ac.tz/logo.png",
    "image": "https://butemine.ac.tz/logo.png",
    "description": "Quality Daycare, Nursery, and Primary education (Std 1–7) in Samunge, Ngorongoro District, Tanzania. Founded 2013.",
    "foundingDate": "2013",
    "telephone": "+255788384699",
    "email": "info@butemine.ac.tz",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Samunge Village, Samunge Ward, Sale Division",
      "addressLocality": "Ngorongoro District",
      "addressRegion": "Arusha",
      "addressCountry": "TZ"
    },
    "sameAs": [
      "https://www.facebook.com/share/1CfGeEVe3b/",
      "https://www.instagram.com/butemineschool"
    ]
  }
  </script>
</head>
