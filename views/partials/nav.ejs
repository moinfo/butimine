      <div class="flex justify-center gap-4 mt-5 pt-5 border-t border-white/10">
        <a href="https://www.facebook.com/share/1CfGeEVe3b/" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-gold-400 transition-colors text-xs">Facebook</a>
        <span class="text-white/20">·</span>
        <a href="https://www.instagram.com/butemineschool" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-gold-400 transition-colors text-xs">Instagram</a>
        <span class="text-white/20">·</span>
        <a href="tel:+255788384699" class="text-white/50 hover:text-gold-400 transition-colors text-xs">+255 788 384 699</a>
      </div>
    </div>
