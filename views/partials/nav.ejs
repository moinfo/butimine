<!-- Mobile backdrop -->
<div id="menu-backdrop" class="fixed inset-0 z-40 bg-bark/50 backdrop-blur-sm hidden lg:hidden"></div>

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group shrink-0">
        <div class="relative logo-pulse">
          <img src="/logo.png" alt="Butemine School" class="h-11 w-11 object-contain rounded-full bg-white/10 p-1 group-hover:scale-105 transition-transform duration-300" />
        </div>
        <div>
          <div class="nav-logo-text font-display font-bold text-base text-white leading-tight group-hover:text-gold-300 transition-colors duration-300">Butemine School</div>
          <div class="text-[10px] text-gold-400 tracking-widest uppercase leading-tight" data-i18n="nav.tagline">Primary School · Tanzania</div>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-6">

        <a href="/"       class="nav-link text-white <%= page === 'home'    ? 'after:!w-full !text-gold-300' : '' %>" data-i18n="nav.home">Home</a>
        <a href="/about"  class="nav-link text-white <%= page === 'about'   ? 'after:!w-full !text-gold-300' : '' %>" data-i18n="nav.about">About</a>
        <a href="/gallery" class="nav-link text-white <%= page === 'gallery' ? 'after:!w-full !text-gold-300' : '' %>" data-i18n="nav.gallery">Gallery</a>

        <!-- Programs Dropdown -->
        <div class="relative" id="programs-dropdown-wrap">
          <button id="programs-btn" aria-expanded="false" aria-haspopup="true"
                  class="nav-link text-white flex items-center gap-1.5 <%= ['schools','admissions','news','results'].includes(page) ? 'after:!w-full !text-gold-300' : '' %>">
            <span data-i18n="nav.programs">Programs</span>
            <svg id="programs-chevron" class="w-3.5 h-3.5 opacity-60 transition-transform duration-300" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </button>

          <!-- Dropdown panel -->
          <div id="programs-menu"
               class="absolute top-[calc(100%+10px)] left-1/2 -translate-x-1/2 w-80
