<%- include('partials/head', { title: 'Our Schools' }) %>
<body class="font-body bg-cream overflow-x-hidden">

<%- include('partials/nav') %>

<!-- Page Hero -->
<section class="page-hero">
  <div class="absolute inset-0 hero-pattern opacity-20"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
    <span class="section-label text-gold-400">Three Centres, One Mission</span>
    <h1 class="font-display text-5xl md:text-6xl font-bold text-white mt-2 mb-4">Our <em class="text-gold-400">Schools</em></h1>
    <p class="text-white/70 text-lg max-w-2xl mx-auto">Bringing quality education closer to the communities that need it most — across Ngorongoro District, Tanzania.</p>
  </div>
</section>

<!-- Overview Stats -->
<section class="bg-bark py-10">
  <div class="max-w-5xl mx-auto px-4">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <% [['3','School Centres'], ['209','Total Students'], ['15+','Teaching Staff'], ['396km','From Arusha']].forEach(([n, l]) => { %>
      <div class="reveal">
        <div class="font-display text-4xl font-bold text-gold-400 mb-1"><%= n %></div>
        <div class="text-white/60 text-xs uppercase tracking-widest"><%= l %></div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- School Centres -->
<section class="py-24 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-20">

    <!-- Centre 1: HQ -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="reveal rounded-3xl overflow-hidden shadow-xl aspect-[4/3] bg-terracotta-100">
        <img src="/images/File 2.jpg" alt="Butemine Headquarters" class="w-full h-full object-cover" />
      </div>
      <div class="reveal">
        <span class="section-label">Centre 01</span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-bark mb-2">
          Butemine <em class="text-terracotta-500">Headquarters</em>
        </h2>
        <p class="text-gold-600 text-sm font-semibold uppercase tracking-widest mb-5">Samunge Village, Ngorongoro District</p>
        <div class="gold-divider mb-6"></div>
        <p class="text-bark/75 leading-relaxed mb-6">The flagship campus and founding centre of Butemine School. This is where John Nedura and Grace Ginduri's vision became reality — a full school offering Nursery, Pre-school, and Primary education.</p>
        <div class="grid grid-cols-2 gap-4 mb-8">
          <% [['147', 'Students'], ['10', 'Teachers'], ['63', 'Fee-exempt Students'], ['1', 'Guard + Secretary']].forEach(([n, l]) => { %>
          <div class="bg-terracotta-50 rounded-xl p-4 border border-terracotta-100">
            <div class="font-display text-2xl font-bold text-terracotta-500"><%= n %></div>
            <div class="text-bark/60 text-xs uppercase tracking-widest mt-1"><%= l %></div>
          </div>
          <% }) %>
        </div>
        <div class="bg-forest-50 rounded-xl p-4 border border-forest-100 text-sm text-forest-700">
          <strong class="font-semibold">Programs:</strong> Daycare · Nursery / Pre-school · Primary (Std 1–7) · Community outreach
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="w-full h-px bg-terracotta-100"></div>

    <!-- Centre 2: Daycare -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="reveal lg:order-2 rounded-3xl overflow-hidden shadow-xl aspect-[4/3] bg-gold-100">
        <img src="/images/File 3.jpg" alt="Sale Branch" class="w-full h-full object-cover" />
      </div>
      <div class="reveal lg:order-1">
        <span class="section-label">Centre 02</span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-bark mb-2">
          Sale <em class="text-gold-500">Branch</em>
        </h2>
        <p class="text-gold-600 text-sm font-semibold uppercase tracking-widest mb-5">Sale Division, Ngorongoro District</p>
        <div class="gold-divider mb-6"></div>
        <p class="text-bark/75 leading-relaxed mb-6">The Sale Branch serves families across Sale Division, Ngorongoro District. Like the Jema Branch, it offers Daycare, Nursery and Pre-school programmes, bringing quality early childhood education closer to the community.</p>
        <div class="grid grid-cols-2 gap-4 mb-8">
          <% [['25', 'Children'], ['2', 'Teachers'], ['1', 'Cook'], ['Sale Div.', 'Location']].forEach(([n, l]) => { %>
          <div class="bg-gold-50 rounded-xl p-4 border border-gold-100">
            <div class="font-display text-2xl font-bold text-gold-600"><%= n %></div>
            <div class="text-bark/60 text-xs uppercase tracking-widest mt-1"><%= l %></div>
          </div>
          <% }) %>
        </div>
        <div class="bg-gold-50 rounded-xl p-4 border border-gold-100 text-sm text-gold-800">
          <strong class="font-semibold">Programs:</strong> Daycare (Ages 0–3) · Nursery · Pre-school
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="w-full h-px bg-terracotta-100"></div>

    <!-- Centre 3: Jema -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="reveal rounded-3xl overflow-hidden shadow-xl aspect-[4/3] bg-forest-100">
        <img src="/images/File 4.jpg" alt="Jema Branch" class="w-full h-full object-cover" />
      </div>
      <div class="reveal">
        <span class="section-label">Centre 03</span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-bark mb-2">
          Jema <em class="text-forest-500">Branch</em>
        </h2>
        <p class="text-gold-600 text-sm font-semibold uppercase tracking-widest mb-5">Jema Village · Near Kenya Border</p>
        <div class="gold-divider mb-6"></div>
        <p class="text-bark/75 leading-relaxed mb-6">Located near the Kenya border, the Jema branch brings Butemine's educational mission to a border community where access to schooling is particularly critical. This centre demonstrates the school's commitment to reaching the most remote students.</p>
        <div class="grid grid-cols-2 gap-4 mb-8">
          <% [['37', 'Students'], ['3', 'Teachers'], ['1', 'Cook'], ['Border', 'Kenya Proximity']].forEach(([n, l]) => { %>
          <div class="bg-forest-50 rounded-xl p-4 border border-forest-100">
            <div class="font-display text-2xl font-bold text-forest-600"><%= n %></div>
            <div class="text-bark/60 text-xs uppercase tracking-widest mt-1"><%= l %></div>
          </div>
          <% }) %>
        </div>
        <div class="bg-forest-50 rounded-xl p-4 border border-forest-100 text-sm text-forest-800">
          <strong class="font-semibold">Programs:</strong> Daycare (Ages 0–3) · Nursery · Pre-school
        </div>
      </div>
    </div>

  </div>
</section>

<!-- Map Placeholder -->
<section class="py-20 bg-bark/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10 reveal">
      <span class="section-label">Find Us</span>
      <h2 class="section-title">Our <em class="text-terracotta-500">Locations</em></h2>
    </div>
    <div class="rounded-3xl overflow-hidden shadow-xl reveal bg-terracotta-100 aspect-video flex items-center justify-center border border-terracotta-200">
      <!-- Replace with actual Google Maps embed -->
      <div class="text-center p-10">
        <svg class="w-16 h-16 text-terracotta-400 mx-auto mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
        </svg>
        <p class="font-display text-xl font-bold text-bark mb-2">Samunge Village, Ngorongoro District</p>
        <p class="text-bark/60 text-sm mb-4">Arusha Region, Tanzania · ~396km from Arusha City</p>
        <a href="https://maps.google.com/?q=Samunge+Village+Ngorongoro+Tanzania" target="_blank" rel="noopener noreferrer" class="btn-primary text-sm">
          Open in Google Maps
        </a>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-16 bg-cream">
  <div class="max-w-3xl mx-auto px-4 text-center reveal">
    <h3 class="font-display text-2xl font-bold text-bark mb-3">Interested in Enrolling?</h3>
    <p class="text-bark/70 mb-8">Visit our admissions page to learn about requirements, fees, and how to apply.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/admissions" class="btn-primary">View Admissions</a>
      <a href="/contact" class="btn-outline-dark">Contact a Campus</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
