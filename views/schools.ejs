<%- include('partials/head', { title: 'Our Schools' }) %>
<body class="font-body bg-cream overflow-x-hidden">

<%- include('partials/nav') %>

<!-- Page Hero -->
<section class="page-hero">
  <div class="absolute inset-0 hero-pattern opacity-20"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
    <span class="section-label text-gold-400"><%= t.schools_hero_label %></span>
    <h1 class="font-display text-5xl md:text-6xl font-bold text-white mt-2 mb-4"><%= t.schools_hero_h_pre %> <em class="text-gold-400"><%= t.schools_hero_h_em %></em></h1>
    <p class="text-white/70 text-lg max-w-2xl mx-auto"><%= t.schools_hero_sub %></p>
  </div>
</section>

<!-- Overview Stats -->
<section class="bg-bark py-10">
  <div class="max-w-5xl mx-auto px-4">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <% [
        ['3',    t.schools_stat_centres],
        ['209',  t.schools_stat_students],
        ['15+',  t.schools_stat_staff],
        ['396km',t.schools_stat_distance],
      ].forEach(([n, l]) => { %>
      <div class="reveal">
        <div class="font-display text-4xl font-bold text-gold-400 mb-1"><%= n %></div>
        <div class="text-white/70 text-xs uppercase tracking-widest"><%= l %></div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- School Centres -->
<section class="py-24 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-20">

    <!-- Centre 1: HQ -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="reveal rounded-3xl overflow-hidden shadow-xl aspect-[4/3] bg-terracotta-100">
        <img src="/images/File 2.jpg" alt="Butemine Headquarters" class="w-full h-full object-cover" />
      </div>
      <div class="reveal">
        <span class="section-label"><%= t.schools_c1_label %></span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-bark mb-2">
          <%= t.schools_c1_h %> <em class="text-terracotta-500"><%= t.schools_c1_h_em %></em>
        </h2>
        <p class="text-gold-600 text-sm font-semibold uppercase tracking-widest mb-5"><%= t.schools_c1_loc %></p>
        <div class="gold-divider mb-6"></div>
        <p class="text-bark/75 leading-relaxed mb-6"><%= t.schools_c1_desc %></p>
        <div class="grid grid-cols-2 gap-4 mb-8">
          <% [['147', t.schools_c1_s1_l], ['10', t.schools_c1_s2_l], ['63', t.schools_c1_s3_l], ['1', t.schools_c1_s4_l]].forEach(([n, l]) => { %>
          <div class="bg-terracotta-50 rounded-xl p-4 border border-terracotta-100">
            <div class="font-display text-2xl font-bold text-terracotta-500"><%= n %></div>
            <div class="text-bark/70 text-xs uppercase tracking-widest mt-1"><%= l %></div>
          </div>
          <% }) %>
        </div>
        <div class="bg-forest-50 rounded-xl p-4 border border-forest-100 text-sm text-forest-700">
          <strong class="font-semibold"><%= t.schools_programs %>:</strong> <%= t.schools_c1_programs %>
        </div>
      </div>
    </div>

    <div class="w-full h-px bg-terracotta-100"></div>

    <!-- Centre 2: Sale Branch -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="reveal lg:order-2 rounded-3xl overflow-hidden shadow-xl aspect-[4/3] bg-gold-100">
        <img src="/images/File 3.jpg" alt="Sale Branch" class="w-full h-full object-cover" />
      </div>
      <div class="reveal lg:order-1">
        <span class="section-label"><%= t.schools_c2_label %></span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-bark mb-2">
          <%= t.schools_c2_h %> <em class="text-gold-500"><%= t.schools_c2_h_em %></em>
        </h2>
        <p class="text-gold-600 text-sm font-semibold uppercase tracking-widest mb-5"><%= t.schools_c2_loc %></p>
        <div class="gold-divider mb-6"></div>
        <p class="text-bark/75 leading-relaxed mb-6"><%= t.schools_c2_desc %></p>
        <div class="grid grid-cols-2 gap-4 mb-8">
          <% [['25', t.schools_c2_s1_l], ['2', t.schools_c2_s2_l], ['1', t.schools_c2_s3_l], [t.schools_c2_s4_n, t.schools_c2_s4_l]].forEach(([n, l]) => { %>
          <div class="bg-gold-50 rounded-xl p-4 border border-gold-100">
            <div class="font-display text-2xl font-bold text-gold-600"><%= n %></div>
            <div class="text-bark/70 text-xs uppercase tracking-widest mt-1"><%= l %></div>
          </div>
          <% }) %>
        </div>
        <div class="bg-gold-50 rounded-xl p-4 border border-gold-100 text-sm text-gold-800">
          <strong class="font-semibold"><%= t.schools_programs %>:</strong> <%= t.schools_c2_programs %>
        </div>
      </div>
    </div>

    <div class="w-full h-px bg-terracotta-100"></div>

    <!-- Centre 3: Jema Branch -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="reveal rounded-3xl overflow-hidden shadow-xl aspect-[4/3] bg-forest-100">
        <img src="/images/File 4.jpg" alt="Jema Branch" class="w-full h-full object-cover" />
      </div>
      <div class="reveal">
        <span class="section-label"><%= t.schools_c3_label %></span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-bark mb-2">
          <%= t.schools_c3_h %> <em class="text-forest-500"><%= t.schools_c3_h_em %></em>
        </h2>
        <p class="text-gold-600 text-sm font-semibold uppercase tracking-widest mb-5"><%= t.schools_c3_loc %></p>
        <div class="gold-divider mb-6"></div>
        <p class="text-bark/75 leading-relaxed mb-6"><%= t.schools_c3_desc %></p>
        <div class="grid grid-cols-2 gap-4 mb-8">
          <% [['37', t.schools_c3_s1_l], ['3', t.schools_c3_s2_l], ['1', t.schools_c3_s3_l], [t.schools_c3_s4_n, t.schools_c3_s4_l]].forEach(([n, l]) => { %>
          <div class="bg-forest-50 rounded-xl p-4 border border-forest-100">
            <div class="font-display text-2xl font-bold text-forest-600"><%= n %></div>
            <div class="text-bark/70 text-xs uppercase tracking-widest mt-1"><%= l %></div>
          </div>
          <% }) %>
        </div>
        <div class="bg-forest-50 rounded-xl p-4 border border-forest-100 text-sm text-forest-800">
          <strong class="font-semibold"><%= t.schools_programs %>:</strong> <%= t.schools_c3_programs %>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- Map -->
<section class="py-20 bg-bark/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10 reveal">
      <span class="section-label"><%= t.schools_map_label %></span>
      <h2 class="section-title"><%= t.schools_map_h %> <em class="text-terracotta-500"><%= t.schools_map_h_em %></em></h2>
    </div>
    <div class="rounded-3xl overflow-hidden shadow-xl reveal bg-terracotta-100 aspect-video flex items-center justify-center border border-terracotta-200">
      <div class="text-center p-10">
        <svg class="w-16 h-16 text-terracotta-400 mx-auto mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
        </svg>
        <p class="font-display text-xl font-bold text-bark mb-2"><%= t.schools_map_address %></p>
        <p class="text-bark/70 text-sm mb-4"><%= t.schools_map_sub %></p>
        <a href="https://maps.google.com/?q=Samunge+Village+Ngorongoro+Tanzania" target="_blank" rel="noopener noreferrer" class="btn-primary text-sm">
          <%= t.schools_map_btn %>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-16 bg-cream">
  <div class="max-w-3xl mx-auto px-4 text-center reveal">
    <h3 class="font-display text-2xl font-bold text-bark mb-3"><%= t.schools_enrol_title %></h3>
    <p class="text-bark/75 mb-8"><%= t.schools_enrol_body %></p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/admissions" class="btn-primary"><%= t.schools_btn_admissions %></a>
      <a href="/contact" class="btn-outline-dark"><%= t.schools_btn_contact %></a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
